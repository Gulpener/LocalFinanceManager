{
  "ConnectionStrings": {
    "Default": "Data Source=localfinancemanager.dev.db"
  },
  "EnableDevSmokeAuth": false,
  "RecreateDatabase": false,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "LocalFinanceManager.Data.Repositories": "Information"
    }
  },
  "BulkAssignUiOptions": {
    "MinimumProcessingVisibleMilliseconds": 1800,
    "CompletionMessageVisibleMilliseconds": 150,
    "ApplyMinimumVisibleDurationOnlyInDevelopment": true
  }
}
