<div class="top-row ps-3">
    <a class="navbar-brand" href="">
        <i class="bi bi-bar-chart-fill me-2"></i>LocalFinanceManager
    </a>
    <button class="hamburger-btn d-md-none" aria-label="Navigatiemenu openen"
            aria-expanded="@_menuOpen.ToString().ToLower()" data-testid="hamburger-btn" @onclick="ToggleMenu">
        <i class="bi bi-list"></i>
    </button>
</div>

@if (_menuOpen)
{
    <div class="nav-overlay d-md-none" @onclick="CloseMenu" data-testid="nav-overlay"></div>
}

<div class="nav-scrollable @(_menuOpen ? "open" : "")">
    <nav class="nav flex-column" @onclick="CloseMenu">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill me-2" aria-hidden="true"></i> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="accounts">
                        <i class="bi bi-wallet-fill me-2" aria-hidden="true"></i> Rekeningen
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="budgets">
                        <i class="bi bi-calculator-fill me-2" aria-hidden="true"></i> Budgetplannen
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="transactions">
                        <i class="bi bi-cash-coin me-2" aria-hidden="true"></i> Transacties
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="sharing/shared-with-me">
                        <i class="bi bi-share-fill me-2" aria-hidden="true"></i> Gedeeld met mij
                        @if (pendingShareCount > 0)
                        {
                            <span class="badge ms-1" data-testid="nav-pending-share-badge">@pendingShareCount</span>
                        }
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/settings">
                        <i class="bi bi-gear-fill me-2" aria-hidden="true"></i> Beheerinstellingen
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/autoapply">
                        <i class="bi bi-robot me-2" aria-hidden="true"></i> Automatisch toewijzen
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/monitoring">
                        <i class="bi bi-speedometer2 me-2" aria-hidden="true"></i> Bewaking
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="backup">
                        <i class="bi bi-cloud-arrow-down-fill me-2" aria-hidden="true"></i> Back-up &amp; herstel
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

@using LocalFinanceManager.Services
@inject ISharingService SharingService
@inject IUserContext UserContext
@inject ILogger<NavMenu> Logger
@implements IDisposable
@code {
    private int pendingShareCount;
    private bool _menuOpen;
    private CancellationTokenSource? _cts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshPendingCountAsync();
            _cts = new CancellationTokenSource();
            _ = RunPeriodicRefreshAsync(_cts.Token);
        }
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;

    private async Task RunPeriodicRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMinutes(1));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshPendingCountAsync();
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on dispose
        }
    }

    private async Task RefreshPendingCountAsync()
    {
        try
        {
            var userId = UserContext.GetCurrentUserId();
            if (userId != Guid.Empty)
            {
                pendingShareCount = await SharingService.GetPendingShareCountAsync(userId);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            // Swallow errors in nav menu to avoid disrupting navigation
            Logger.LogWarning(ex, "Failed to refresh pending share count.");
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}