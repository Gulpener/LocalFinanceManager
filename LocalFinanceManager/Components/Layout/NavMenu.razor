<div class="sidebar-wrap @(_collapsed ? "collapsed" : "")" data-testid="sidebar-wrap">
<div class="top-row ps-3">
    <a class="navbar-brand" href="">
        <i class="bi bi-bar-chart-fill" aria-hidden="true"></i><span class="nav-label ms-2">LocalFinanceManager</span>
    </a>
    <button class="hamburger-btn d-md-none" aria-label="Navigatiemenu openen"
            aria-expanded="@_menuOpen.ToString().ToLower()" data-testid="hamburger-btn" @onclick="ToggleMenu">
        <i class="bi bi-list"></i>
    </button>
</div>

@if (_menuOpen)
{
    <div class="nav-overlay d-md-none" @onclick="CloseMenu" data-testid="nav-overlay"></div>
}

<div class="nav-scrollable @(_menuOpen ? "open" : "")">
    <nav class="nav flex-column" @onclick="CloseMenu">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill" aria-hidden="true"></i><span class="nav-label ms-2">Home</span>
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="accounts">
                        <i class="bi bi-wallet-fill" aria-hidden="true"></i><span class="nav-label ms-2">Rekeningen</span>
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="budgets">
                        <i class="bi bi-calculator-fill" aria-hidden="true"></i><span class="nav-label ms-2">Budgetplannen</span>
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="transactions">
                        <i class="bi bi-cash-coin" aria-hidden="true"></i><span class="nav-label ms-2">Transacties</span>
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="sharing/shared-with-me">
                        <i class="bi bi-share-fill" aria-hidden="true"></i><span class="nav-label ms-2">Gedeeld met mij</span>
                        @if (pendingShareCount > 0)
                        {
                            <span class="badge ms-1" data-testid="nav-pending-share-badge">@pendingShareCount</span>
                        }
                    </NavLink>
                </div>

                @if (_isAdmin)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/settings" data-testid="nav-admin-link">
                            <i class="bi bi-shield-lock-fill" aria-hidden="true"></i><span class="nav-label ms-2">Beheer</span>
                        </NavLink>
                    </div>
                }

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="settings/auto-apply">
                        <i class="bi bi-robot" aria-hidden="true"></i><span class="nav-label ms-2">Automatisch toewijzen</span>
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="backup">
                        <i class="bi bi-cloud-arrow-down-fill" aria-hidden="true"></i><span class="nav-label ms-2">Back-up &amp; herstel</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
    <button class="sidebar-collapse-btn" aria-label="@(_collapsed ? "Zijbalk uitklappen" : "Zijbalk inklappen")"
            data-testid="sidebar-collapse-btn" @onclick="ToggleSidebarAsync">
        <i class="bi @(_collapsed ? "bi-chevron-right" : "bi-chevron-left")" aria-hidden="true"></i>
    </button>
</div>
</div>

@using LocalFinanceManager.Services
@inject ISharingService SharingService
@inject IUserContext UserContext
@inject ILogger<NavMenu> Logger
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IDisposable
@code {
    private int pendingShareCount;
    private bool _menuOpen;
    private bool _collapsed;
    private bool _isAdmin;
    private CancellationTokenSource? _cts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            NavigationManager.LocationChanged += OnLocationChanged;
            await RefreshPendingCountAsync();
            _cts = new CancellationTokenSource();
            _ = WarmUpNavStateAsync(_cts.Token);
            _ = RunPeriodicRefreshAsync(_cts.Token);
            try
            {
                _collapsed = await JS.InvokeAsync<bool>("window.sidebar.getCollapsed");
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Could not read sidebar collapsed state from localStorage");
            }
        }
    }

    private async Task ToggleSidebarAsync()
    {
        _collapsed = !_collapsed;
        try
        {
            await JS.InvokeVoidAsync("window.sidebar.setCollapsed", _collapsed);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not persist sidebar collapsed state to localStorage");
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _menuOpen = false;
        _ = RefreshPendingCountAsync();
        InvokeAsync(StateHasChanged);
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;

    private async Task RunPeriodicRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMinutes(1));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshPendingCountAsync();
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on dispose
        }
    }

    private async Task RefreshPendingCountAsync()
    {
        var userId = UserContext.GetCurrentUserId();
        if (userId == Guid.Empty)
        {
            var stateResetNeeded = pendingShareCount != 0 || _isAdmin;
            pendingShareCount = 0;
            _isAdmin = false;
            if (stateResetNeeded)
            {
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        var stateChanged = false;

        try
        {
            pendingShareCount = await SharingService.GetPendingShareCountAsync(userId);
            stateChanged = true;
        }
        catch (Exception ex)
        {
            // Swallow errors in nav menu to avoid disrupting navigation
            Logger.LogWarning(ex, "Failed to refresh pending share count.");
        }

        try
        {
            _isAdmin = await UserContext.IsAdminAsync();
            stateChanged = true;
        }
        catch (Exception ex)
        {
            // Swallow errors in nav menu to avoid disrupting navigation
            Logger.LogWarning(ex, "Failed to refresh admin navigation state.");
        }

        if (stateChanged)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task WarmUpNavStateAsync(CancellationToken cancellationToken)
    {
        // Retry for a short period so menu state catches up when circuit user initializes after first render.
        try
        {
            for (var attempt = 0; attempt < 10 && !cancellationToken.IsCancellationRequested; attempt++)
            {
                await Task.Delay(TimeSpan.FromMilliseconds(300), cancellationToken);

                if (UserContext.GetCurrentUserId() == Guid.Empty)
                {
                    continue;
                }

                await RefreshPendingCountAsync();
                return;
            }
        }
        catch (OperationCanceledException)
        {
            // Expected during component disposal.
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}