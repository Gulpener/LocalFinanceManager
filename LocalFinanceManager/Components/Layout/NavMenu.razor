<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">LocalFinanceManager</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="accounts">
                        <span class="bi bi-wallet-fill" aria-hidden="true"></span> Accounts
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="transactions">
                        <span class="bi bi-cash-coin" aria-hidden="true"></span> Transacties
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="budgets">
                        <span class="bi bi-calculator-fill" aria-hidden="true"></span> Budget Plans
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="sharing/shared-with-me">
                        <span class="bi bi-share-fill" aria-hidden="true"></span> Shared with Me
                        @if (pendingShareCount > 0)
                        {
                            <span class="badge bg-warning text-dark ms-1">@pendingShareCount</span>
                        }
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/settings">
                        <span class="bi bi-gear-fill" aria-hidden="true"></span> Admin Settings
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/autoapply">
                        <span class="bi bi-robot" aria-hidden="true"></span> Auto-Apply
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/monitoring">
                        <span class="bi bi-speedometer2" aria-hidden="true"></span> Monitoring
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

@using LocalFinanceManager.Services
@inject ISharingService SharingService
@inject IUserContext UserContext
@implements IDisposable
@code {
    private int pendingShareCount;
    private System.Threading.Timer? _timer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshPendingCountAsync();
            _timer = new System.Threading.Timer(async _ =>
            {
                await RefreshPendingCountAsync();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
        }
    }

    private async Task RefreshPendingCountAsync()
    {
        try
        {
            var userId = UserContext.GetCurrentUserId();
            if (userId != Guid.Empty)
            {
                pendingShareCount = await SharingService.GetPendingShareCountAsync(userId);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Swallow errors in nav menu to avoid disrupting navigation
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}