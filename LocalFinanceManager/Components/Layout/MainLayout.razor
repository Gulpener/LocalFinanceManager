@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject LocalFinanceManager.Services.IDeviceDetectionService DeviceDetectionService

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@* ShortcutHelp is rendered on specific pages (e.g., Transactions) to avoid duplicate modal IDs. *@

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool showShortcutHelp;
    private bool isTouchDevice;
    private bool isMacOs;
    private DotNetObjectReference<MainLayout>? dotNetRef;
    private bool globalShortcutsRegistered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        isTouchDevice = await DeviceDetectionService.IsTouchDeviceAsync();
        var os = await DeviceDetectionService.GetOperatingSystemAsync();
        isMacOs = os == LocalFinanceManager.Services.ClientOperatingSystem.MacOS;

        if (!isTouchDevice)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.registerGlobalShortcuts", dotNetRef, "HandleGlobalShortcut");
            globalShortcutsRegistered = true;
        }

        StateHasChanged();
    }

    [JSInvokable]
    public Task HandleGlobalShortcut(string key)
    {
        if (key == "?" && !showShortcutHelp)
        {
            showShortcutHelp = true;
            StateHasChanged();
        }
        else if (key == "Escape" && showShortcutHelp)
        {
            showShortcutHelp = false;
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    private Task CloseShortcutHelp()
    {
        showShortcutHelp = false;
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (globalShortcutsRegistered)
            {
                await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.unregisterGlobalShortcuts");
            }
        }
        catch (Microsoft.JSInterop.JSDisconnectedException)
        {
            // Ignore disconnection during disposal; circuit is already closed.
        }
        catch (Microsoft.JSInterop.JSException)
        {
            // Ignore JS errors during disposal to avoid teardown failures.
        }

        dotNetRef?.Dispose();
    }
}