@inherits LayoutComponentBase
@using LocalFinanceManager.Services
@using LocalFinanceManager.Components.Shared
@inject IBreadcrumbService BreadcrumbService
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me-2 fw-semibold text-body">Ingelogd</span>
                    <span class="me-3">Hello, @context.User.Identity?.Name</span>
                    <a href="/logout" class="nav-link">Logout</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="nav-link me-2">Login</a>
                    <a href="/register" class="nav-link">Register</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <div class="px-4 pt-2">
            <Breadcrumb Items="@_breadcrumbs" />
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@* ShortcutHelp is rendered on specific pages (e.g., Transactions) to avoid duplicate modal IDs. *@

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private List<Breadcrumb.BreadcrumbItem> _breadcrumbs = new();

    protected override void OnInitialized()
    {
        BreadcrumbService.OnChange += HandleBreadcrumbChange;
        UpdateBreadcrumbs();
    }

    private void HandleBreadcrumbChange()
        => InvokeAsync(() => { UpdateBreadcrumbs(); StateHasChanged(); });

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = BreadcrumbService.Items
            .Select(i => new Breadcrumb.BreadcrumbItem(i.Text, i.Href))
            .ToList();
    }

    public void Dispose() => BreadcrumbService.OnChange -= HandleBreadcrumbChange;
}
