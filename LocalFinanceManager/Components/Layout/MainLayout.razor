@inherits LayoutComponentBase
@using LocalFinanceManager.Services
@using LocalFinanceManager.Components.Shared
@inject IBreadcrumbService BreadcrumbService
@inject IThemeService ThemeService
@inject IUserContext UserContext
@inject ILogger<MainLayout> Logger
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me-auto fw-semibold text-body"
                          data-testid="topbar-username">@context.User.Identity?.Name</span>
                    <button class="btn btn-link theme-toggle-btn me-2" aria-label="Thema wisselen"
                            data-testid="theme-toggle" @onclick="ToggleThemeAsync">
                        @if (ThemeService.CurrentTheme == "dark")
                        {
                            <i class="bi bi-sun" aria-hidden="true"></i>
                        }
                        else
                        {
                            <i class="bi bi-moon" aria-hidden="true"></i>
                        }
                    </button>
                    <a href="/logout" class="nav-link">Uitloggen</a>
                </Authorized>
                <NotAuthorized>
                    <button class="btn btn-link theme-toggle-btn me-2" aria-label="Thema wisselen"
                            data-testid="theme-toggle" @onclick="ToggleThemeAsync">
                        @if (ThemeService.CurrentTheme == "dark")
                        {
                            <i class="bi bi-sun" aria-hidden="true"></i>
                        }
                        else
                        {
                            <i class="bi bi-moon" aria-hidden="true"></i>
                        }
                    </button>
                    <a href="/login" class="nav-link me-2">Inloggen</a>
                    <a href="/register" class="nav-link">Registreren</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <div class="px-4 pt-2">
            <Breadcrumb Items="@_breadcrumbs" />
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Er is een onverwachte fout opgetreden.
    <a href="." class="reload">Herladen</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private List<Breadcrumb.BreadcrumbItem> _breadcrumbs = new();
    private bool _themeInitialised;
    private bool _themeInitialisedWithEmptyUser;

    protected override void OnInitialized()
    {
        BreadcrumbService.OnChange += HandleBreadcrumbChange;
        ThemeService.ThemeChanged += HandleThemeChanged;
        UpdateBreadcrumbs();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var userId = UserContext.GetCurrentUserId();

        if (!_themeInitialised)
        {
            _themeInitialised = true;
            _themeInitialisedWithEmptyUser = userId == Guid.Empty;
            try
            {
                await ThemeService.InitialiseAsync(userId);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                // Theme initialisation failure must never crash the Blazor circuit.
                // Log and continue — the default light theme stays in effect.
                Logger.LogWarning(ex, "Theme initialisation failed; default light theme will be used");
            }
        }
        else if (_themeInitialisedWithEmptyUser && userId != Guid.Empty)
        {
            // Circuit user became available after first render; re-initialise so the DB
            // preference is loaded instead of falling back to OS preference.
            _themeInitialisedWithEmptyUser = false;
            try
            {
                await ThemeService.InitialiseAsync(userId);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Theme re-initialisation failed; current theme will be kept");
            }
        }
    }

    private async Task ToggleThemeAsync()
    {
        var userId = UserContext.GetCurrentUserId();
        await ThemeService.ToggleAsync(userId);
    }

    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);

    private void HandleBreadcrumbChange()
        => InvokeAsync(() => { UpdateBreadcrumbs(); StateHasChanged(); });

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = BreadcrumbService.Items
            .Select(i => new Breadcrumb.BreadcrumbItem(i.Text, i.Href))
            .ToList();
    }

    public void Dispose()
    {
        BreadcrumbService.OnChange -= HandleBreadcrumbChange;
        ThemeService.ThemeChanged -= HandleThemeChanged;
    }
}
