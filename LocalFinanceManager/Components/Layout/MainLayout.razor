@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@* ShortcutHelp is rendered on specific pages (e.g., Transactions) to avoid duplicate modal IDs. *@

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.unregisterGlobalShortcuts");
        }
        catch (Microsoft.JSInterop.JSDisconnectedException)
        {
            // Ignore disconnection during disposal; circuit is already closed.
        }
        catch (Microsoft.JSInterop.JSException)
        {
            // Ignore JS errors during disposal to avoid teardown failures.
        }
    }
}