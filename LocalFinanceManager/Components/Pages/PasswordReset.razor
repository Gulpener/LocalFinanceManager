@page "/password-reset"
@using LocalFinanceManager.Services
@inject IAuthService AuthService

<PageTitle>Password Reset</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2>Reset Password</h2>

        @if (emailSent)
        {
            <div class="alert alert-success">
                Password reset email sent. Check your inbox.
            </div>
            <p><a href="/login">Back to login</a></p>
        }
        else
        {
            <p>Enter your email address and we'll send you a link to reset your password.</p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="@resetModel" OnValidSubmit="HandlePasswordReset" FormName="password-reset">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <InputText id="email" class="form-control" @bind-Value="resetModel.Email"
                               type="email" autocomplete="email" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@isSubmitting">
                    @(isSubmitting ? "Sending..." : "Send reset email")
                </button>
            </EditForm>

            <hr />
            <p class="text-center">
                <a href="/login">Back to login</a>
            </p>
        }
    </div>
</div>

@code {
    private ResetModel resetModel = new();
    private string? errorMessage;
    private bool isSubmitting;
    private bool emailSent;

    private async Task HandlePasswordReset()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            await AuthService.SendPasswordResetEmailAsync(resetModel.Email);
            emailSent = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ResetModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
