@page "/password-reset"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using LocalFinanceManager.Services
@inject IAuthService AuthService

<PageTitle>Wachtwoord opnieuw instellen</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2>Wachtwoord opnieuw instellen</h2>

        @if (emailSent)
        {
            <div class="alert alert-success">
                Herstelmail verstuurd. Controleer uw inbox.
            </div>
            <p><a href="/login">Terug naar inloggen</a></p>
        }
        else
        {
            <p>Voer uw e-mailadres in en we sturen u een link om uw wachtwoord opnieuw in te stellen.</p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="@resetModel" OnValidSubmit="HandlePasswordReset" FormName="password-reset">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="email" class="form-label">E-mailadres</label>
                    <InputText id="email" class="form-control" @bind-Value="resetModel.Email" type="email"
                               autocomplete="email" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@isSubmitting">
                    @(isSubmitting ? "Bezig..." : "Stuur herstelmail")
                </button>
            </EditForm>

            <hr />
            <p class="text-center">
                <a href="/login">Terug naar inloggen</a>
            </p>
        }
    </div>
</div>

@code {
    private ResetModel resetModel = new();
    private string? errorMessage;
    private bool isSubmitting;
    private bool emailSent;

    private async Task HandlePasswordReset()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.SendPasswordResetEmailAsync(resetModel.Email);
            if (result.Success)
            {
                emailSent = true;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Versturen van herstelmail mislukt. Probeer het opnieuw.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ResetModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
