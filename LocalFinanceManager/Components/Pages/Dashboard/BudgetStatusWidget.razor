@using LocalFinanceManager.Services
@using LocalFinanceManager.DTOs
@inject BudgetPlanService BudgetPlanService

<div class="card h-100">
    <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted text-uppercase small">Budgetstatus</h6>
        @if (_isLoading)
        {
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm" role="status"></div>
            </div>
        }
        else if (!_lines.Any())
        {
            <p class="text-muted small">Geen budgetregels voor de huidige maand.</p>
        }
        else
        {
            @foreach (var item in _lines.Take(5))
            {
                var pct = item.Budget > 0 ? (int)Math.Min((item.Spent / item.Budget) * 100, 100) : 0;
                var isOver = item.Budget > 0 && item.Spent > item.Budget;
                <div class="mb-2">
                    <div class="d-flex justify-content-between small">
                        <span class="@(isOver ? "text-danger fw-bold" : "")">@item.Name</span>
                        <span>@item.Spent.ToString("N2") / @item.Budget.ToString("N2")</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar @(isOver ? "bg-danger" : "bg-success")" style="width: @pct%"></div>
                    </div>
                </div>
            }
            <a href="/budgets" class="btn btn-sm btn-outline-secondary mt-2">Alle budgetplannen</a>
        }
    </div>
</div>

@code {
    [Parameter] public List<AccountResponse>? Accounts { get; set; }

    private bool _isLoading = true;
    private List<(string Name, decimal Budget, decimal Spent)> _lines = new();

    protected override async Task OnInitializedAsync()
    {
        if (Accounts == null || Accounts.Count == 0)
        {
            _isLoading = false;
            return;
        }

        try
        {
            var currentMonth = DateTime.Today.Month;
            var currentYear = DateTime.Today.Year;

            foreach (var account in Accounts)
            {
                var plan = await BudgetPlanService.GetByAccountAndYearAsync(account.Id, currentYear);
                if (plan == null) continue;

                foreach (var line in plan.BudgetLines)
                {
                    var monthlyBudget = line.MonthlyAmounts.Length >= currentMonth
                        ? line.MonthlyAmounts[currentMonth - 1] : 0;
                    _lines.Add((line.CategoryName, monthlyBudget, 0m));
                }
                break; // show first account's current plan
            }
        }
        finally
        {
            _isLoading = false;
        }
    }
}
