@using LocalFinanceManager.DTOs

<div class="kpi-card @(TotalBalance < 0 ? "kpi-danger" : "kpi-success")" data-testid="kpi-total-balance">
    <span class="kpi-label">Totaal saldo</span>
    <span class="kpi-value">
        @(TotalBalance < 0 ? "-" : "")€@Math.Abs(TotalBalance).ToString("N2")
    </span>
    <span class="kpi-sub">@AccountCount rekening(en)</span>
</div>

@code {
    [Parameter] public decimal TotalBalance { get; set; }
    [Parameter] public int AccountCount { get; set; }
}
