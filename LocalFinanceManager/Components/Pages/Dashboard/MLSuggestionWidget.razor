@using LocalFinanceManager.Models

<div class="card h-100">
    <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted text-uppercase small">Onverdeelde Transacties</h6>
        @if (Transactions == null)
        {
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm" role="status"></div>
            </div>
        }
        else if (_candidateCount == 0)
        {
            <p class="text-muted small">Alle transacties zijn toegewezen.</p>
        }
        else
        {
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-exclamation-circle text-warning"></i>
                <span class="fs-5 fw-bold">@_candidateCount</span>
                <span class="text-muted small">onverdeelde transacties</span>
            </div>
            <a href="/transactions?filter=unassigned" class="btn btn-sm btn-warning text-dark">
                Transacties toewijzen
            </a>
        }
    </div>
</div>

@code {
    [Parameter] public List<Transaction>? Transactions { get; set; }

    private int _candidateCount;

    protected override void OnParametersSet()
    {
        if (Transactions == null) return;
        // Count unassigned transactions that are candidates for ML suggestions
        _candidateCount = Transactions.Count(t => !t.IsSplit && (t.AssignedParts == null || !t.AssignedParts.Any()));
    }
}
