@page "/register"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using LocalFinanceManager.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Registreren</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2>Registreren</h2>

        @if (registrationSuccess)
        {
            <div class="alert alert-success">
                Registratie geslaagd! Controleer uw e-mail om uw account te verifiëren voordat u inlogt.
            </div>
            <p><a href="/login">Naar inloggen</a></p>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="register">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="email" class="form-label">E-mailadres</label>
                    <InputText id="email" class="form-control" @bind-Value="registerModel.Email" type="email"
                               autocomplete="email" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Wachtwoord</label>
                    <InputText id="password" class="form-control" @bind-Value="registerModel.Password" type="password"
                               autocomplete="new-password" />
                </div>

                <div class="mb-3">
                    <label for="confirmPassword" class="form-label">Wachtwoord bevestigen</label>
                    <InputText id="confirmPassword" class="form-control" @bind-Value="registerModel.ConfirmPassword"
                               type="password" autocomplete="new-password" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@isSubmitting">
                    @(isSubmitting ? "Bezig..." : "Account aanmaken")
                </button>
            </EditForm>

            <hr />
            <p class="text-center">
                Al een account? <a href="/login">Inloggen</a>
            </p>
        }
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private bool isSubmitting;
    private bool registrationSuccess;

    private async Task HandleRegister()
    {
        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Wachtwoorden komen niet overeen.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.SignUpAsync(registerModel.Email, registerModel.Password);

            if (result.Success)
            {
                registrationSuccess = true;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Registratie mislukt. Probeer het opnieuw.";
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
