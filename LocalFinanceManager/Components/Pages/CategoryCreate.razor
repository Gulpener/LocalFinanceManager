@page "/budgets/{budgetPlanId:guid}/categories/new"
@using LocalFinanceManager.Services
@using LocalFinanceManager.DTOs
@using LocalFinanceManager.Models
@using LocalFinanceManager.Components.Shared
@using static LocalFinanceManager.Components.Shared.Breadcrumb
@inject CategoryService CategoryService
@inject BudgetPlanService BudgetPlanService
@inject NavigationManager Navigation
@inject ILogger<CategoryCreate> Logger
@rendermode InteractiveServer

<PageTitle>Nieuwe Categorie</PageTitle>

@if (budgetPlan == null)
{
    <p><em>Budget plan laden...</em></p>
}
else
{
    <Breadcrumb Items="@breadcrumbItems" />

    <h1>Nieuwe Categorie Aanmaken</h1>

    <div class="row">
        <div class="col-md-6">
            <EditForm Model="@categoryName" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <div class="mb-3">
                    <label for="name" class="form-label">Naam</label>
                    <InputText id="name" class="form-control" @bind-Value="categoryName" />
                    @if (validationErrors.ContainsKey("Name"))
                    {
                        <div class="text-danger">@string.Join(", ", validationErrors["Name"])</div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Type</label>
                    <div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="type" id="typeIncome"
                                   checked="@(categoryType == CategoryType.Income)"
                                   @onclick="@(() => categoryType = CategoryType.Income)" />
                            <label class="form-check-label" for="typeIncome">
                                Inkomsten
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="type" id="typeExpense"
                                   checked="@(categoryType == CategoryType.Expense)"
                                   @onclick="@(() => categoryType = CategoryType.Expense)" />
                            <label class="form-check-label" for="typeExpense">
                                Uitgaven
                            </label>
                        </div>
                    </div>
                    @if (validationErrors.ContainsKey("Type"))
                    {
                        <div class="text-danger">@string.Join(", ", validationErrors["Type"])</div>
                    }
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Aanmaken...</span>
                        }
                        else
                        {
                            <span>Categorie Aanmaken</span>
                        }
                    </button>
                    <a href="/budgets/@BudgetPlanId/edit" class="btn btn-secondary">Annuleren</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid BudgetPlanId { get; set; }

    private BudgetPlanDto? budgetPlan;
    private List<BreadcrumbItem> breadcrumbItems = new();
    private string categoryName = string.Empty;
    private CategoryType categoryType = CategoryType.Expense;
    private Dictionary<string, string[]> validationErrors = new();
    private string? errorMessage;
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadBudgetPlan();
    }

    private async Task LoadBudgetPlan()
    {
        try
        {
            budgetPlan = await BudgetPlanService.GetByIdAsync(BudgetPlanId);
            if (budgetPlan == null)
            {
                errorMessage = "Budget plan niet gevonden.";
                return;
            }

            breadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Budget Plans", "/budgets"),
                new BreadcrumbItem(budgetPlan.Name, $"/budgets/{BudgetPlanId}/edit"),
                new BreadcrumbItem("Categorieën", null),
                new BreadcrumbItem("Nieuw", null)
            };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load budget plan {BudgetPlanId} for category creation.", BudgetPlanId);
            errorMessage = "Fout bij laden van budget plan.";
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        validationErrors.Clear();

        try
        {
            var request = new CreateCategoryDto
            {
                Name = categoryName,
                Type = categoryType,
                BudgetPlanId = BudgetPlanId
            };
            var response = await CategoryService.CreateAsync(request);
            Navigation.NavigateTo($"/budgets/{BudgetPlanId}/edit");
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "HTTP error while creating category for budget plan {BudgetPlanId}.", BudgetPlanId);
            errorMessage = "Fout bij aanmaken van categorie.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error while creating category for budget plan {BudgetPlanId}.", BudgetPlanId);
            errorMessage = "Fout bij aanmaken van categorie.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}