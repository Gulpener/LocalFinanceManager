@page "/budgets"
@attribute [Authorize]
@using LocalFinanceManager.Services
@using LocalFinanceManager.DTOs
@using LocalFinanceManager.Models
@using LocalFinanceManager.Components.Pages.Sharing
@using Microsoft.JSInterop
@inject BudgetPlanService BudgetPlanService
@inject AccountService AccountService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Budgetplannen</PageTitle>

<h1>Budgetplannen</h1>

<div class="mb-3">
    <div class="row">
        <div class="col-md-6">
            <label for="accountSelect" class="form-label">Rekening selecteren</label>
            <select id="accountSelect" class="form-select" @onchange="OnAccountChanged">
                <option value="">-- Selecteer een rekening --</option>
                @if (accounts != null)
                {
                    @foreach (var account in accounts)
                    {
                        <option value="@account.Id" selected="@(selectedAccountId == account.Id)">
                            @account.Label (@account.Currency)
                        </option>
                    }
                }
            </select>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            @if (selectedAccountId != Guid.Empty)
            {
                <button class="btn btn-primary" @onclick="CreateNewPlan">
                    <i class="bi bi-plus-circle"></i> Nieuw budgetplan aanmaken
                </button>
            }
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <select class="form-select" @bind="_ownerFilter" @bind:after="StateHasChanged">
                <option value="all">Alle</option>
                <option value="mine">Mijn plannen</option>
                <option value="shared">Gedeeld met mij</option>
            </select>
        </div>
    </div>
</div>

@if (isLoading)
{
    <p><em>Budgetplannen laden...</em></p>
}
else if (selectedAccountId == Guid.Empty)
{
    <div class="alert alert-info">
        <p>Selecteer een rekening om de bijbehorende budgetplannen te bekijken.</p>
    </div>
}
else if (budgetPlans == null || !FilteredPlans.Any())
{
    <div class="alert alert-info">
        <p>Geen budgetplannen gevonden voor deze rekening. Maak uw eerste budgetplan aan om te beginnen!</p>
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Jaar</th>
                <th>Naam</th>
                <th>Budgetregels</th>
                <th>Aangemaakt</th>
                <th>Acties</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var plan in FilteredPlans)
            {
                <tr>
                    <td>@plan.Year</td>
                    <td>
                        @plan.Name
                        <span class="ms-2 badge @PermissionBadgeClass(plan.UserPermission)">@plan.UserPermission</span>
                        @if (plan.UserPermission != PermissionLevel.Owner && !string.IsNullOrEmpty(plan.OwnerEmail))
                        {
                            <div class="text-muted small">Gedeeld door @plan.OwnerEmail</div>
                        }
                    </td>
                    <td>@plan.BudgetLines.Count</td>
                    <td>@plan.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        <div class="d-flex flex-wrap gap-1 align-items-center">
                            @if (plan.UserPermission == PermissionLevel.Owner || plan.UserPermission == PermissionLevel.Editor)
                            {
                                <a href="/budgets/@plan.Id/edit" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i> Bewerken
                                </a>
                            }
                            @if (plan.UserPermission == PermissionLevel.Owner)
                            {
                                <button class="btn btn-sm btn-outline-success" @onclick="() => OpenShareModal(plan)">
                                    <i class="bi bi-share"></i> Delen
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => ArchivePlan(plan.Id)">
                                    <i class="bi bi-archive"></i> Archiveren
                                </button>
                            }
                            else if (plan.UserPermission == PermissionLevel.Viewer)
                            {
                                <span class="badge bg-secondary">Alleen lezen</span>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Share Modal -->
<ShareModal IsVisible="showShareModal" ResourceId="shareModalPlanId" ResourceName="shareModalPlanName"
            Type="ShareModal.ResourceType.BudgetPlan" OnClose="CloseShareModal" OnShareCreated="CloseShareModal" />

@code {
    private List<AccountResponse>? accounts;
    private List<BudgetPlanDto>? budgetPlans;
    private Guid selectedAccountId = Guid.Empty;
    private bool isLoading = false;
    private string _ownerFilter = "all";

    private IEnumerable<BudgetPlanDto> FilteredPlans => (budgetPlans ?? Enumerable.Empty<BudgetPlanDto>())
        .Where(p => _ownerFilter switch
        {
            "mine" => p.UserPermission == PermissionLevel.Owner,
            "shared" => p.UserPermission != PermissionLevel.Owner,
            _ => true
        });

    private static string PermissionBadgeClass(PermissionLevel level) => level switch
    {
        PermissionLevel.Owner => "bg-primary",
        PermissionLevel.Editor => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private bool showShareModal;
    private Guid shareModalPlanId;
    private string shareModalPlanName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();
    }

    private async Task LoadAccounts()
    {
        accounts = await AccountService.GetAllActiveAsync();
        if (accounts.Any())
        {
            selectedAccountId = accounts.First().Id;
            await LoadBudgetPlans();
        }
    }

    private async Task LoadBudgetPlans()
    {
        if (selectedAccountId == Guid.Empty) return;

        isLoading = true;
        budgetPlans = await BudgetPlanService.GetByAccountIdAsync(selectedAccountId);
        isLoading = false;
    }

    private async Task OnAccountChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var accountId))
        {
            selectedAccountId = accountId;
            await LoadBudgetPlans();
        }
        else
        {
            selectedAccountId = Guid.Empty;
            budgetPlans = null;
        }
    }

    private void CreateNewPlan()
    {
        Navigation.NavigateTo($"/budgets/new?accountId={selectedAccountId}");
    }

    private void OpenShareModal(BudgetPlanDto plan)
    {
        shareModalPlanId = plan.Id;
        shareModalPlanName = plan.Name;
        showShareModal = true;
    }

    private void CloseShareModal()
    {
        showShareModal = false;
    }

    private async Task ArchivePlan(Guid planId)
    {
        try
        {
            bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to archive this budget plan?");
            if (confirmed)
            {
                await BudgetPlanService.ArchiveAsync(planId);
                await LoadBudgetPlans();
            }
        }
        catch (JSDisconnectedException)
        {
            // Client disconnected, silently ignore
        }
        catch (InvalidOperationException)
        {
            // JSInterop not available (prerendering or disconnected), silently ignore
        }
    }
}