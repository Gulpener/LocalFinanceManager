@page "/accounts"
@attribute [Authorize]
@using LocalFinanceManager.Services
@using LocalFinanceManager.DTOs
@using LocalFinanceManager.Models
@using LocalFinanceManager.Components.Pages.Sharing
@inject AccountService AccountService
@inject NavigationManager Navigation
@inject ILogger<Accounts> Logger
@inject IUserContext UserContext
@rendermode InteractiveServer

<PageTitle>Accounts</PageTitle>

<h1>Accounts</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <a href="/accounts/new" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Account
    </a>
    <select class="form-select" style="width: auto;" @bind="_ownerFilter" @bind:after="StateHasChanged">
        <option value="all">All accounts</option>
        <option value="mine">Owned by Me</option>
        <option value="shared">Shared with Me</option>
    </select>
</div>

@if (accounts == null)
{
    <p><em>Loading accounts...</em></p>
}
else if (!FilteredAccounts.Any())
{
    <div class="alert alert-info">
        <p>No accounts found. Create your first account to get started!</p>
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Label</th>
                <th>Type</th>
                <th>Currency</th>
                <th>IBAN</th>
                <th class="text-end">Current Balance</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var account in FilteredAccounts)
            {
                <tr>
                    <td>
                        @account.Label
                        <span class="ms-2 badge @PermissionBadgeClass(account.PermissionLevel)">
                            @account.PermissionLevel
                        </span>
                        @if (account.PermissionLevel != PermissionLevel.Owner && !string.IsNullOrEmpty(account.OwnerEmail))
                        {
                            <div class="text-muted small">Gedeeld door @account.OwnerEmail</div>
                        }
                    </td>
                    <td>@account.Type</td>
                    <td>@account.Currency</td>
                    <td>@FormatIban(account.IBAN)</td>
                    <td class="text-end">@account.CurrentBalance.ToString("N2")</td>
                    <td>
                        @if (account.PermissionLevel == PermissionLevel.Owner || account.PermissionLevel ==
                                        PermissionLevel.Editor)
                        {
                            <a href="/accounts/@account.Id/edit" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        }
                        @if (account.PermissionLevel == PermissionLevel.Owner)
                        {
                            <button class="btn btn-sm btn-outline-success" @onclick="() => OpenShareModal(account)">
                                <i class="bi bi-share"></i> Share
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmArchive(account)">
                                <i class="bi bi-archive"></i> Archive
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Share Modal -->
<ShareModal IsVisible="showShareModal" ResourceId="shareModalAccountId" ResourceName="shareModalAccountLabel"
            Type="ShareModal.ResourceType.Account" OnClose="CloseShareModal" OnShareCreated="CloseShareModal" />

<!-- Archive Confirmation Modal -->
@if (accountToArchive != null)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Archive</h5>
                    <button type="button" class="btn-close" @onclick="CancelArchive"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to archive the account "<strong>@accountToArchive.Label</strong>"?</p>
                    <p class="text-muted">Archived accounts will be hidden from the list but can be restored later.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelArchive">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ArchiveAccount">Archive</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<AccountResponse>? accounts;
    private AccountResponse? accountToArchive;
    private string? errorMessage;
    private Guid currentUserId;
    private string _ownerFilter = "all";

    private bool showShareModal;
    private Guid shareModalAccountId;
    private string shareModalAccountLabel = string.Empty;

    private IEnumerable<AccountResponse> FilteredAccounts => (accounts ?? Enumerable.Empty<AccountResponse>())
        .Where(a => _ownerFilter switch
        {
            "mine" => a.PermissionLevel == PermissionLevel.Owner,
            "shared" => a.PermissionLevel != PermissionLevel.Owner,
            _ => true
        });

    protected override async Task OnInitializedAsync()
    {
        currentUserId = UserContext.GetCurrentUserId();
        await LoadAccounts();
    }

    private async Task LoadAccounts()
    {
        try
        {
            accounts = await AccountService.GetAllActiveAsync();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load accounts.");
            errorMessage = "Could not load accounts.";
        }
    }

    private void ConfirmArchive(AccountResponse account) => accountToArchive = account;

    private void OpenShareModal(AccountResponse account)
    {
        shareModalAccountId = account.Id;
        shareModalAccountLabel = account.Label;
        showShareModal = true;
    }

    private void CloseShareModal() => showShareModal = false;

    private void CancelArchive() => accountToArchive = null;

    private async Task ArchiveAccount()
    {
        if (accountToArchive == null) return;
        var accountId = accountToArchive.Id;
        try
        {
            await AccountService.ArchiveAsync(accountId);
            accountToArchive = null;
            await LoadAccounts();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to archive account {AccountId}.", accountId);
            errorMessage = "Could not archive account.";
        }
    }

    private static string PermissionBadgeClass(PermissionLevel level) => level switch
    {
        PermissionLevel.Owner => "bg-primary",
        PermissionLevel.Editor => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private string FormatIban(string iban)
    {
        if (string.IsNullOrWhiteSpace(iban)) return iban;
        return string.Join(" ", Enumerable.Range(0, (iban.Length + 3) / 4)
            .Select(i => iban.Substring(i * 4, Math.Min(4, iban.Length - i * 4))));
    }
}