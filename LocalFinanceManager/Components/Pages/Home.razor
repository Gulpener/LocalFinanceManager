@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using LocalFinanceManager.Services
@using LocalFinanceManager.Components.Pages.Dashboard
@using LocalFinanceManager.Data.Repositories
@using LocalFinanceManager.Models
@using LocalFinanceManager.DTOs
@using Microsoft.AspNetCore.Components.Authorization
@inject AccountService AccountService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ITransactionRepository TransactionRepository
@inject ILogger<Home> Logger

<PageTitle>Dashboard</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (_isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Laden...</span>
                </div>
            </div>
        }
        else if (_accounts != null && _accounts.Count == 0)
        {
            <div class="container text-center py-5" data-testid="dashboard-empty">
                <i class="bi bi-house-door text-muted" style="font-size: 4rem;"></i>
                <h2 class="mt-3">Welkom bij Local Finance Manager</h2>
                <p class="text-muted mb-4">
                    U heeft nog geen rekeningen. Start de wizard om uw eerste rekening en budgetplan aan te maken.
                </p>
                <a href="/onboarding" class="btn btn-primary btn-lg">
                    <i class="bi bi-magic"></i> Onboarding starten
                </a>
            </div>
        }
        else
        {
            <div data-testid="dashboard">
                <h1 class="mb-4">Dashboard</h1>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <AccountSummaryWidget Accounts="_accounts" />
                    </div>
                    <div class="col-md-6">
                        <BudgetStatusWidget Accounts="_accounts" />
                    </div>
                    <div class="col-md-6">
                        <UncategorizedAlertWidget UnassignedCount="_unassignedCount" />
                    </div>
                    <div class="col-md-6">
                        <MLSuggestionWidget Transactions="_transactions" />
                    </div>
                    <div class="col-12">
                        <RecentTransactionsWidget Transactions="_transactions" />
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-3 text-muted text-uppercase small">Snelle acties</h6>
                        <div class="d-flex flex-wrap gap-2">
                            <a href="/accounts/new" class="btn btn-outline-primary">
                                <i class="bi bi-plus-circle"></i> Rekening aanmaken
                            </a>
                            <a href="/budgets/new" class="btn btn-outline-primary">
                                <i class="bi bi-clipboard-plus"></i> Budgetplan aanmaken
                            </a>
                            <a href="/transactions/import" class="btn btn-outline-primary">
                                <i class="bi bi-upload"></i> Transacties importeren
                            </a>
                            <a href="/transactions" class="btn btn-outline-secondary">
                                <i class="bi bi-list-ul"></i> Alle transacties
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container text-center py-5">
            <h1 class="display-4 mb-3">Local Finance Manager</h1>
            <p class="lead text-muted mb-4">
                Beheer uw financiën eenvoudig en overzichtelijk. Volg uw rekeningen, budgetten en transacties op één
                plek.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/login" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Inloggen
                </a>
                <a href="/register" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-person-plus"></i> Registreren
                </a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<AccountResponse>? _accounts;
    private List<Transaction>? _transactions;
    private int? _unassignedCount;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (!(authState.User.Identity?.IsAuthenticated ?? false))
            {
                return;
            }

            _accounts = await AccountService.GetAllActiveAsync();
            // Only load recent transactions when there are accounts; avoids a heavy full-table scan
            // on first-time users and limits data transfer to what the widgets actually display.
            if (_accounts.Count > 0)
            {
                _transactions = await TransactionRepository.GetRecentWithSplitsAsync(50);
                _unassignedCount = await TransactionRepository.CountUnassignedAsync();
            }
            else
            {
                _transactions = new List<Transaction>();
                _unassignedCount = 0;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard data");
            _accounts ??= new();
            _transactions ??= new();
        }
        finally
        {
            _isLoading = false;
        }
    }
}

