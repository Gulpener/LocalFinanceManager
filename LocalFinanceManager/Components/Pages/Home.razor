@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using LocalFinanceManager.Services
@using LocalFinanceManager.Components.Pages.Dashboard
@using LocalFinanceManager.Data.Repositories
@using LocalFinanceManager.Models
@using LocalFinanceManager.DTOs
@using Microsoft.AspNetCore.Components.Authorization
@inject AccountService AccountService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ITransactionRepository TransactionRepository

<PageTitle>Dashboard</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (_isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Laden...</span>
                </div>
            </div>
        }
        else
        {
            <div data-testid="dashboard">
                <h1 class="mb-4">Dashboard</h1>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <AccountSummaryWidget Accounts="_accounts" />
                    </div>
                    <div class="col-md-6">
                        <BudgetStatusWidget Accounts="_accounts" />
                    </div>
                    <div class="col-md-6">
                        <UncategorizedAlertWidget Transactions="_transactions" />
                    </div>
                    <div class="col-md-6">
                        <MLSuggestionWidget Transactions="_transactions" />
                    </div>
                    <div class="col-12">
                        <RecentTransactionsWidget Transactions="_transactions" />
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-3 text-muted text-uppercase small">Snelle acties</h6>
                        <div class="d-flex flex-wrap gap-2">
                            <a href="/accounts/new" class="btn btn-outline-primary">
                                <i class="bi bi-plus-circle"></i> Rekening aanmaken
                            </a>
                            <a href="/budgets/new" class="btn btn-outline-primary">
                                <i class="bi bi-clipboard-plus"></i> Budgetplan aanmaken
                            </a>
                            <a href="/transactions/import" class="btn btn-outline-primary">
                                <i class="bi bi-upload"></i> Transacties importeren
                            </a>
                            <a href="/transactions" class="btn btn-outline-secondary">
                                <i class="bi bi-list-ul"></i> Alle transacties
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container text-center py-5">
            <h1 class="display-4 mb-3">Local Finance Manager</h1>
            <p class="lead text-muted mb-4">
                Beheer uw financiën eenvoudig en overzichtelijk. Volg uw rekeningen, budgetten en transacties op één
                plek.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/login" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Inloggen
                </a>
                <a href="/register" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-person-plus"></i> Registreren
                </a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<AccountResponse>? _accounts;
    private List<Transaction>? _transactions;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (!(authState.User.Identity?.IsAuthenticated ?? false))
            {
                return;
            }

            _accounts = await AccountService.GetAllActiveAsync();
            _transactions = await TransactionRepository.GetAllWithSplitsAsync();

            if (_accounts.Count == 0)
            {
                Navigation.NavigateTo("/onboarding");
            }
        }
        catch
        {
            _accounts ??= new();
            _transactions ??= new();
        }
        finally
        {
            _isLoading = false;
        }
    }
}

