@page "/transactions/{Id:guid}/audit"
@attribute [Authorize]
@using LocalFinanceManager.DTOs
@using LocalFinanceManager.Services
@using LocalFinanceManager.Data.Repositories
@inject ITransactionAssignmentService AssignmentService
@inject ITransactionRepository TransactionRepository
@inject ILogger<TransactionAudit> Logger
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Audit Trail - Transactie</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="/transactions" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left" aria-hidden="true"></i> Terug
    </a>
    <h1 class="mb-0">Audit Trail</h1>
</div>

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Laden...</span>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle" aria-hidden="true"></i> @errorMessage
    </div>
}
else
{
    @if (transaction != null)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">@transaction.Description</h5>
                <p class="card-text text-muted">
                    <span class="@(transaction.Amount >= 0 ? "text-success" : "text-danger")">
                        @transaction.Amount.ToString("C2")
                    </span>
                    &bull; @transaction.Date.ToString("dd-MM-yyyy")
                    @if (!string.IsNullOrEmpty(transaction.Counterparty))
                    {
                        <span> &bull; @transaction.Counterparty</span>
                    }
                </p>
            </div>
        </div>
    }

    <div data-testid="audit-trail-container">
        @if (auditEntries == null || !auditEntries.Any())
        {
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle" aria-hidden="true"></i> Geen auditgeschiedenis gevonden voor deze transactie.
            </div>
        }
        else
        {
            <p class="text-muted mb-3">@auditEntries.Count audit @(auditEntries.Count == 1 ? "entry" : "entries") gevonden</p>

            <div class="timeline">
                @foreach (var entry in GetPagedEntries())
                {
                    var entryClass = entry.IsAutoApplied ? "border-primary" : "border-secondary";
                    <div class="timeline-item mb-3" data-testid="audit-entry" data-entry-id="@entry.Id">
                        <div class="card @entryClass" style="border-left-width: 4px;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                            <span class="badge @GetActionBadgeClass(entry.ActionType)"
                                                  data-testid="audit-action-type">
                                                <i class="bi @GetActionIcon(entry.ActionType) me-1"></i>
                                                @GetActionText(entry.ActionType)
                                            </span>
                                            @if (entry.IsAutoApplied)
                                            {
                                                <span class="badge bg-primary" data-testid="auto-applied-badge">
                                                    🤖 Auto-applied
                                                    @if (entry.Confidence.HasValue)
                                                    {
                                                        <span data-testid="confidence-score">
                                                            (@((entry.Confidence.Value * 100).ToString("F0"))% zekerheid)
                                                        </span>
                                                    }
                                                </span>
                                                @if (entry.ModelVersion.HasValue)
                                                {
                                                    <span class="badge bg-light text-dark border" data-testid="model-version">
                                                        Model v@entry.ModelVersion
                                                    </span>
                                                }
                                            }
                                        </div>
                                        <p class="card-text text-muted mb-1">
                                            <small>
                                                <i class="bi bi-person me-1"></i>
                                                <span data-testid="audit-actor">@entry.ChangedBy</span>
                                            </small>
                                        </p>
                                        <p class="card-text text-muted mb-0">
                                            <small>
                                                <i class="bi bi-clock me-1"></i>
                                                <span data-testid="audit-timestamp"
                                                      title="@entry.ChangedAt.ToString("dd-MM-yyyy HH:mm:ss")">
                                                    @GetRelativeTime(entry.ChangedAt)
                                                </span>
                                            </small>
                                        </p>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(entry.Reason))
                                {
                                    <div class="mt-2">
                                        <strong>Reden:</strong>
                                        <p class="mb-0" data-testid="audit-reason">@entry.Reason</p>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(entry.BeforeState) || !string.IsNullOrEmpty(entry.AfterState))
                                {
                                    <div class="mt-2">
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => ToggleStateExpanded(entry.Id)"
                                                aria-expanded="@expandedEntries.Contains(entry.Id)">
                                            <i class="bi @(expandedEntries.Contains(entry.Id) ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>
                                            @(expandedEntries.Contains(entry.Id) ? "Verberg" : "Toon") statuswijzigingen
                                        </button>

                                        @if (expandedEntries.Contains(entry.Id))
                                        {
                                            <div class="mt-2 row">
                                                @if (!string.IsNullOrEmpty(entry.BeforeState))
                                                {
                                                    <div class="col-md-6 mb-2">
                                                        <strong class="text-danger">Voor:</strong>
                                                        <pre class="mt-1 mb-0 p-2 bg-light border rounded small"
                                                             data-testid="before-state"><code>@entry.BeforeState</code></pre>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(entry.AfterState))
                                                {
                                                    <div class="col-md-6 mb-2">
                                                        <strong class="text-success">Na:</strong>
                                                        <pre class="mt-1 mb-0 p-2 bg-light border rounded small"
                                                             data-testid="after-state"><code>@entry.AfterState</code></pre>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (GetTotalPages() > 1)
            {
                <nav aria-label="Audit trail paginering" class="mt-3">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage - 1)"
                                    disabled="@(currentPage == 1)" aria-label="Vorige">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @for (var p = 1; p <= GetTotalPages(); p++)
                        {
                            var pageNum = p;
                            <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == GetTotalPages() ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage + 1)"
                                    disabled="@(currentPage == GetTotalPages())" aria-label="Volgende">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private const int PageSize = 20;

    private List<TransactionAuditDto>? auditEntries;
    private TransactionDto? transaction;
    private string? errorMessage;
    private bool loading = true;
    private int currentPage = 1;
    private HashSet<Guid> expandedEntries = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            loading = true;
            errorMessage = null;

            var tx = await TransactionRepository.GetByIdWithAccountAsync(Id);
            if (tx == null)
            {
                transaction = null;
                auditEntries = null;
                errorMessage = "Transactie niet gevonden of niet toegankelijk.";
                return;
            }

            transaction = new TransactionDto
            {
                Id = tx.Id,
                Amount = tx.Amount,
                Date = tx.Date,
                Description = tx.Description,
                Counterparty = tx.Counterparty,
                AccountId = tx.AccountId
            };

            auditEntries = await AssignmentService.GetTransactionAuditHistoryAsync(Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load audit trail for transaction {TransactionId}", Id);
            errorMessage = "Fout bij het laden van de auditgeschiedenis.";
        }
        finally
        {
            loading = false;
        }
    }

    private void ToggleStateExpanded(Guid entryId)
    {
        if (!expandedEntries.Remove(entryId))
        {
            expandedEntries.Add(entryId);
        }
    }

    private int totalAuditEntries;

    private async Task GoToPageAsync(int page)
    {
        var totalPages = GetTotalPages();
        var newPage = Math.Clamp(page, 1, totalPages);

        if (newPage == currentPage)
        {
            return;
        }

        currentPage = newPage;
        await LoadAuditEntriesPageAsync();
    }

    private List<TransactionAuditDto> GetPagedEntries() =>
        auditEntries ?? new List<TransactionAuditDto>();

    private int GetTotalPages() =>
        totalAuditEntries <= 0
            ? 1
            : (int)Math.Ceiling((double)totalAuditEntries / PageSize);

    private async Task LoadAuditEntriesPageAsync()
    {
        // This component should treat `auditEntries` as the current page only.
        // Wire this method to a server-side paged service/repository call in the
        // existing load logic so only one page is fetched per request.
        await Task.CompletedTask;
    }

    private static string GetRelativeTime(DateTime changedAt)
    {
        var diff = DateTime.UtcNow - changedAt.ToUniversalTime();
        if (diff.TotalMinutes < 1) return "Zojuist";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} minuten geleden";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} uur geleden";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} dagen geleden";
        return changedAt.ToString("dd-MM-yyyy");
    }

    private static string GetActionIcon(string actionType) =>
        actionType.ToLowerInvariant() switch
        {
            "assign" or "manualassign" => "bi-plus-circle",
            "reassign" => "bi-arrow-repeat",
            "unassign" or "undo" => "bi-dash-circle",
            "split" => "bi-scissors",
            "bulk_assign" or "bulkassign" => "bi-collection",
            "autoapply" or "autoassign" => "bi-robot",
            "import" => "bi-upload",
            "validationfailed" or "validationerror" => "bi-exclamation-triangle",
            _ => "bi-pencil"
        };

    private static string GetActionText(string actionType) =>
        actionType.ToLowerInvariant() switch
        {
            "assign" or "manualassign" => "Handmatig toegewezen",
            "reassign" => "Opnieuw toegewezen",
            "unassign" => "Toewijzing verwijderd",
            "undo" => "Ongedaan gemaakt",
            "split" => "Gesplitst",
            "bulk_assign" or "bulkassign" => "Bulk toewijzing",
            "autoapply" or "autoassign" => "Auto-toewijzing",
            "import" => "Geïmporteerd",
            "validationfailed" or "validationerror" => "Validatie mislukt",
            _ => actionType
        };

    private static string GetActionBadgeClass(string actionType) =>
        actionType.ToLowerInvariant() switch
        {
            "assign" or "manualassign" => "bg-success",
            "reassign" => "bg-info",
            "unassign" or "undo" => "bg-warning text-dark",
            "split" => "bg-primary",
            "bulk_assign" or "bulkassign" => "bg-secondary",
            "autoapply" or "autoassign" => "bg-primary",
            "import" => "bg-light text-dark border",
            "validationfailed" or "validationerror" => "bg-danger",
            _ => "bg-light text-dark"
        };
}
