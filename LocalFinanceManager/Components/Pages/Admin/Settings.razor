@page "/admin/settings"
@inject IWebHostEnvironment Environment
@inject AppDbContext DbContext
@using LocalFinanceManager.Data
@using Microsoft.EntityFrameworkCore
@using Npgsql

<PageTitle>Admin Settings</PageTitle>

<h3>Systeem Instellingen</h3>

<div class="card">
    <div class="card-header">
        <h5>Environment Informatie</h5>
    </div>
    <div class="card-body">
        <table class="table table-borderless">
            <tbody>
                <tr>
                    <th scope="row">Environment:</th>
                    <td>
                        <span class="badge @_environmentBadgeClass">@Environment.EnvironmentName</span>
                    </td>
                </tr>
                <tr>
                    <th scope="row">Application Name:</th>
                    <td>@Environment.ApplicationName</td>
                </tr>
                <tr>
                    <th scope="row">Content Root Path:</th>
                    <td><code>@Environment.ContentRootPath</code></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        <h5>Database Configuratie</h5>
    </div>
    <div class="card-body">
        <table class="table table-borderless">
            <tbody>
                <tr>
                    <th scope="row">Connection String:</th>
                    <td><code>@_maskedConnectionString</code></td>
                </tr>
                <tr>
                    <th scope="row">Database Host:</th>
                    <td><code>@_databaseHost</code></td>
                </tr>
                <tr>
                    <th scope="row">Database Name:</th>
                    <td><code>@_databaseName</code></td>
                </tr>
                <tr>
                    <th scope="row">Database Verbinding:</th>
                    <td>
                        @if (_databaseExists)
                        {
                            <span class="badge bg-success" aria-label="Database verbonden">Verbonden</span>
                        }
                        else
                        {
                            <span class="badge bg-danger" aria-label="Database niet bereikbaar">Niet bereikbaar</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th scope="row">Laatst Uitgevoerde Migratie:</th>
                    <td><code>@_lastMigration</code></td>
                </tr>
                <tr>
                    <th scope="row">Pending Migrations:</th>
                    <td>
                        @if (_pendingMigrations?.Any() == true)
                        {
                            <span class="badge bg-warning" aria-label="Pending migrations">@_pendingMigrations.Count()
                                pending</span>
                                <ul class="mt-2">
                                    @foreach (var migration in _pendingMigrations)
                                    {
                                        <li><code>@migration</code></li>
                                    }
                                </ul>
                            }
                        else
                            {
                                <span class="badge bg-success" aria-label="Geen pending migrations">Geen</span>
                            }
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">
            <h5>Seed Data Status</h5>
        </div>
        <div class="card-body">
            <table class="table table-borderless">
                <tbody>
                    <tr>
                        <th scope="row">Accounts:</th>
                        <td>@_accountCount records</td>
                    </tr>
                    <tr>
                        <th scope="row">Categories:</th>
                        <td>@_categoryCount records</td>
                    </tr>
                    <tr>
                        <th scope="row">Budget Plans:</th>
                        <td>@_budgetPlanCount records</td>
                    </tr>
                    <tr>
                        <th scope="row">Budget Lines:</th>
                        <td>@_budgetLineCount records</td>
                    </tr>
                    <tr>
                        <th scope="row">Transactions:</th>
                        <td>@_transactionCount records</td>
                    </tr>
                    <tr>
                        <th scope="row">Transaction Splits:</th>
                        <td>@_transactionSplitCount records</td>
                    </tr>
                    <tr>
                        <th scope="row">Seed Data Geladen:</th>
                        <td>
                            @if (_seedDataLoaded)
                            {
                                <span class="badge bg-success" aria-label="Seed data geladen">Ja</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Nee (Production of handmatig geleegd)</span>
                            }
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

@code {
    private string? _connectionString;
    private string? _maskedConnectionString;
    private string? _databaseHost;
    private string? _databaseName;
    private bool _databaseExists;
    private string? _lastMigration;
    private IEnumerable<string>? _pendingMigrations;
    private int _accountCount;
    private int _categoryCount;
    private int _budgetPlanCount;
    private int _budgetLineCount;
    private int _transactionCount;
    private int _transactionSplitCount;
    private bool _seedDataLoaded;
    private string _environmentBadgeClass = "bg-secondary";

    protected override async Task OnInitializedAsync()
    {
        // Environment badge color
        _environmentBadgeClass = Environment.IsDevelopment() ? "bg-primary" : "bg-danger";

        // Connection string - read from the actual runtime DbConnection so the displayed
        // values always match what the app is actually using (not just what's in config).
        _connectionString = DbContext.Database.GetDbConnection().ConnectionString;

        // Parse and mask PostgreSQL connection string details
        if (!string.IsNullOrEmpty(_connectionString))
        {
            try
            {
                var csb = new NpgsqlConnectionStringBuilder(_connectionString);
                _databaseHost = csb.Host;
                _databaseName = csb.Database;
                // Mask password for display
                csb.Password = string.IsNullOrEmpty(csb.Password) ? null : "***";
                _maskedConnectionString = csb.ToString();
            }
            catch
            {
                // Fallback: mask any Password= segment before displaying
                _maskedConnectionString = System.Text.RegularExpressions.Regex.Replace(
                    _connectionString, @"(?i)(password\s*=\s*)[^;]*", "$1***");
            }
        }

        // Check database connectivity
        _databaseExists = await DbContext.Database.CanConnectAsync();

        // Database migrations info
        var appliedMigrations = await DbContext.Database.GetAppliedMigrationsAsync();
        _lastMigration = appliedMigrations.LastOrDefault() ?? "Geen";
        _pendingMigrations = await DbContext.Database.GetPendingMigrationsAsync();

        // Seed data status
        _accountCount = await DbContext.Accounts.CountAsync();
        _categoryCount = await DbContext.Categories.CountAsync();
        _budgetPlanCount = await DbContext.BudgetPlans.CountAsync();
        _budgetLineCount = await DbContext.BudgetLines.CountAsync();
        _transactionCount = await DbContext.Transactions.CountAsync();
        _transactionSplitCount = await DbContext.TransactionSplits.CountAsync();
        _seedDataLoaded = _accountCount > 0 && _categoryCount > 0;
    }
}