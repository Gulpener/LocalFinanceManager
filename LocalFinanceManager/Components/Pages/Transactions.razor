@page "/transactions"
@attribute [Authorize]
@using LocalFinanceManager.DTOs
@using LocalFinanceManager.Data.Repositories
@using LocalFinanceManager.Services
@using LocalFinanceManager.ML
@inject ITransactionRepository TransactionRepository
@inject IAccountRepository AccountRepository
@inject IDeviceDetectionService DeviceDetectionService
@inject IUserContext UserContext
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject ILogger<Transactions> Logger
@inject IMLService MLService
@implements IAsyncDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Transacties</PageTitle>

<h1 @onkeydown:window="HandleGlobalKeyDown">Transacties
    <button type="button" class="btn btn-sm btn-outline-secondary ms-2" @onclick="() => showShortcutHelp = true"
            id="shortcutHelpButton" data-testid="shortcut-help-button" title="Toetsenbord sneltoetsen"
            aria-label="Toetsenbord sneltoetsen">
        <i class="bi bi-question-circle"></i>
    </button>
</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<ShortcutHelp IsVisible="showShortcutHelp" IsTouchDevice="isTouchDevice" IsMacOs="isMacOs"
              OnClose="@(() => showShortcutHelp = false)" />

<!-- Quick Filters -->
<QuickFilters CurrentFilters="filterState" OnFiltersChanged="OnFiltersChanged" />

<div class="row mb-3">
    <div class="col-md-6">
        <label for="account-filter" class="form-label">Filter op rekening:</label>
        <select id="account-filter" class="form-select" @bind="selectedAccountIdString" @bind:after="OnAccountChanged">
            <option value="">Alle rekeningen</option>
            @foreach (var account in accounts)
            {
                <option value="@account.Id">@account.Label</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label for="suggestion-filter" class="form-label">ML suggestie:</label>
        <select id="suggestion-filter" class="form-select" @bind="_suggestionFilter" @bind:after="ApplyFilters">
            <option value="all">Alle transacties</option>
            <option value="has-suggestion">Heeft ML suggestie</option>
            <option value="no-suggestion">Geen ML suggestie</option>
        </select>
        @if (_suggestionFilter != "all")
        {
            <small class="text-muted">Filter is gebaseerd op de eerste 100 onverdeelde transacties.</small>
        }
    </div>
    <div class="col-md-3">
        <label for="sort-by" class="form-label">Sorteren op:</label>
        <select id="sort-by" class="form-select" @bind="_sortBy" @bind:after="ApplyFilters">
            <option value="date-desc">Datum (nieuwste eerst)</option>
            <option value="confidence-desc">Zekerheid (hoog → laag)</option>
        </select>
    </div>
</div>

<div class="mb-3">
    <a href="/transactions/import" class="btn btn-primary">
        <i class="bi bi-upload"></i> Importeer transacties
    </a>
</div>

<div data-testid="transactions-list-container" data-filter-assignment="@filterState.AssignmentStatus"
     data-loaded-account="@loadedAccountId">

    @if (loading)
    {
        <TransactionListSkeleton RowCount="10" />
    }
    else if (filteredTransactions.Count == 0)
    {
        <div class="alert alert-info" data-testid="no-transactions-message">
            Geen transacties gevonden. @(selectedAccountId.HasValue ? "Selecteer een andere rekening of " : "")
            <a href="/transactions/import">Importeer transacties</a> om te beginnen.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover" data-testid="transactions-table">
                <thead>
                    <tr>
                        <th style="width: 40px;">
                            <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll"
                                   checked="@(selectedTransactionIds.Count == filteredTransactions.Count && filteredTransactions.Any())"
                                   aria-label="Selecteer alle zichtbare transacties" title="Selecteer alles" />
                        </th>
                        <th>Status</th>
                        <th>Datum</th>
                        <th>Beschrijving</th>
                        <th>Tegenpartij</th>
                        <th>Bedrag</th>
                        <th>Toewijzing</th>
                        <th>Acties</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < filteredTransactions.Count; index++)
                    {
                        var transaction = filteredTransactions[index];
                        <tr @key="transaction.Id"
                            class="transaction-row @(selectedTransactionIds.Contains(transaction.Id) ? "table-primary" : "")"
                            data-testid="transaction-row" data-row-index="@index" data-transaction-id="@transaction.Id"
                            tabindex="@(focusedRowIndex == index ? 0 : -1)" @onfocus="() => SetFocusedRow(index)"
                            @onkeydown="HandleTableKeyDown">
                            <td>
                                <input type="checkbox" class="form-check-input"
                                       checked="@selectedTransactionIds.Contains(transaction.Id)"
                                       aria-label="@($"Selecteer transactie {transaction.Description}")"
                                       @onchange="() => ToggleSelectTransaction(transaction.Id)" />
                            </td>
                            <td>
                                @if (!transaction.IsAssigned)
                                {
                                    <span class="badge bg-warning text-dark" title="Transactie niet toegewezen aan categorie"
                                          aria-label="Niet toegewezen">
                                        <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                                        <span class="visually-hidden">Niet toegewezen</span>
                                    </span>
                                }
                                else if (transaction.Splits != null && transaction.Splits.Count > 1)
                                {
                                    <span class="badge bg-info" title="Gesplitste transactie" aria-label="Gesplitst">
                                        <i class="bi bi-distribute-vertical" aria-hidden="true"></i>
                                        <span class="visually-hidden">Gesplitst</span>
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success" title="Transactie toegewezen" aria-label="Toegewezen">
                                        <i class="bi bi-check-circle" aria-hidden="true"></i>
                                        <span class="visually-hidden">Toegewezen</span>
                                    </span>
                                }
                            </td>
                            <td>@transaction.Date.ToString("dd-MM-yyyy")</td>
                            <td>@transaction.Description</td>
                            <td>@transaction.Counterparty</td>
                            <td class="amount @(transaction.Amount >= 0 ? "amount-positive" : "amount-negative")">
                                @CurrencyFormatter.Format(transaction.Amount, transaction.AccountCurrency)
                            </td>
                            <td>
                                @if (transaction.IsAssigned && transaction.Splits != null)
                                {
                                    @if (transaction.Splits.Count > 1)
                                    {
                                        <span class="badge bg-info text-dark me-1"
                                              title="@string.Join(", ", transaction.Splits.Select(s => $"{s.BudgetLineName}: {CurrencyFormatter.Format(s.Amount, transaction.AccountCurrency)}"))">
                                            @transaction.Splits.Count splits
                                        </span>
                                    }
                                    else
                                    {
                                        @foreach (var split in transaction.Splits)
                                        {
                                            <span class="badge bg-info text-dark me-1">@split.BudgetLineName</span>
                                        }
                                    }
                                }
                                else if (!transaction.IsAssigned)
                                {
                                    <MLSuggestionBadge TransactionId="@transaction.Id"
                                                       OnSuggestionAccepted="@(async () => await OnSuggestionAccepted(transaction.Id))"
                                                       OnConfidenceLoaded="@((float conf) => HandleConfidenceLoaded(transaction.Id, conf))" />
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => OpenAssignModal(transaction)"
                                        title="@(transaction.IsAssigned ? "Wijzig toewijzing" : "Wijs toe")">
                                    <i class="bi bi-pencil"></i> @(transaction.IsAssigned ? "Wijzig" : "Toewijzen")
                                </button>
                                <button class="btn btn-sm btn-outline-secondary me-1"
                                        @onclick="() => OpenSplitEditor(transaction)" title="Splits transactie">
                                    <i class="bi bi-distribute-vertical"></i> Split
                                </button>
                                @if (transaction.IsAssigned)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenAuditTrail(transaction.Id)"
                                            title="Bekijk toewijzingsgeschiedenis" aria-label="Bekijk toewijzingsgeschiedenis">
                                        <i class="bi bi-clock-history" aria-hidden="true"></i>
                                    </button>
                                }
                                <a href="/transactions/@transaction.Id/audit"
                                   class="btn btn-sm btn-outline-secondary ms-1"
                                   title="Audit Trail pagina" data-testid="audit-trail-link">
                                    <i class="bi bi-clock-history" aria-hidden="true"></i> Audit Trail
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th></th>
                        <th colspan="4" class="text-end">Totaal (gefilterd):</th>
                        <th class="@(filteredTotalAmount >= 0 ? "text-success" : "text-danger")">
                            @if (SelectedAccountCurrency != null)
                            {
                                @CurrencyFormatter.Format(filteredTotalAmount, SelectedAccountCurrency)
                            }
                            else
                            {
                                <span class="text-muted fst-italic">meerdere valuta</span>
                            }
                        </th>
                        <th colspan="2"></th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <p class="text-muted">
            @filteredTransactions.Count van @transactionDtos.Count transactie(s) weergegeven
            @if (unassignedCount > 0)
            {
                <span class="text-body-secondary">(@unassignedCount niet toegewezen)</span>
            }
        </p>
    }

</div>

<TransactionAssignModal Transaction="@selectedTransaction" IsVisible="@showAssignModal" OnClose="@CloseAssignModal"
                        OnAssignmentSuccess="@OnAssignmentSuccess" />

<SplitEditor Transaction="@splitTransaction" IsVisible="@showSplitEditor" OnClose="@CloseSplitEditor"
             OnSplitSaved="@OnSplitSaved" />

<BulkAssignModal TransactionIds="@selectedTransactionIds" BudgetPlanId="@GetBulkBudgetPlanId()"
                 IsVisible="@showBulkAssignModal" OnClose="@CloseBulkAssignModal" OnBulkAssigned="@OnBulkAssigned" />

<AssignmentAuditTrail TransactionId="@auditTransactionId" IsVisible="@showAuditTrail" OnClose="@CloseAuditTrail" />


@if (selectedTransactionIds.Any())
{
    <div class="position-fixed bottom-0 start-50 translate-middle-x mb-3" data-testid="bulk-action-bar"
         style="z-index: 1050;">
        <div class="card shadow-lg">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-primary fs-6">@selectedTransactionIds.Count geselecteerd</span>
                    <button class="btn btn-sm btn-primary" @onclick="OpenBulkAssignModal">
                        <i class="bi bi-check-all"></i> Bulk toewijzen
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearSelection">
                        <i class="bi bi-x-circle"></i> Deselecteer alles
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TransactionDto> transactionDtos = new();
    private List<TransactionDto> filteredTransactions = new();
    private List<LocalFinanceManager.Models.Account> accounts = new();
    private Guid? selectedAccountId = null;
    private string selectedAccountIdString = "";
    private bool loading = true;
    private string loadedAccountId = "all";
    private decimal filteredTotalAmount = 0;
    private int unassignedCount = 0;
    private FilterState filterState = new();

    private string? SelectedAccountCurrency
    {
        get
        {
            if (selectedAccountId.HasValue)
            {
                return accounts.FirstOrDefault(a => a.Id == selectedAccountId.Value)?.Currency;
            }

            var distinctCurrencies = filteredTransactions
                .Select(t => t.AccountCurrency)
                .Where(currency => !string.IsNullOrWhiteSpace(currency))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Take(2)
                .ToList();

            return distinctCurrencies.Count == 1
                ? distinctCurrencies[0]
                : null;
        }
    }

    // ML suggestion filter and sort state
    private string _suggestionFilter = "all";
    private string _sortBy = "date-desc";
    private Dictionary<Guid, float> _suggestionConfidences = new();

    private bool showAssignModal = false;
    private TransactionDto? selectedTransaction = null;

    private bool showSplitEditor = false;
    private TransactionDto? splitTransaction = null;

    private bool showBulkAssignModal = false;
    private List<Guid> selectedTransactionIds = new();

    private bool showAuditTrail = false;
    private Guid? auditTransactionId = null;

    private bool showShortcutHelp;
    private bool isTouchDevice;
    private bool isMacOs;
    private string? errorMessage;
    private int focusedRowIndex;
    private bool touchDeviceDetected;
    private DotNetObjectReference<Transactions>? dotNetRef;
    private bool globalShortcutsRegistered;
    private bool _initialized;
    private int _afterRenderRetries;
    private bool _lastLoadHadEmptyUser;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAccountsAsync();
            await LoadTransactionsAsync();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize Transactions page");
            errorMessage = "Kon transacties niet laden. Vernieuw de pagina of probeer opnieuw in te loggen.";
            loading = false;
        }

        _initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Retry loading transactions when the page loaded with an empty result:
        // • Up to 3 retries while the circuit user is initializing (Guid.Empty race condition).
        // • Exactly 1 fallback retry for any other reason (e.g., CI/timing edge cases).
        //   Limiting to one fallback retry reduces redundant loads for users with zero transactions
        //   (down from 3 to 1) while preserving reliability in E2E and CI environments.
        var maxRetries = _lastLoadHadEmptyUser ? 3 : 1;
        if (transactionDtos.Count == 0 && _initialized && !loading && _afterRenderRetries < maxRetries)
        {
            _afterRenderRetries++;
            await LoadTransactionsAsync();
            StateHasChanged();
        }

        if (!firstRender || touchDeviceDetected)
        {
            return;
        }

        try
        {
            isTouchDevice = await DeviceDetectionService.IsTouchDeviceAsync();
            var os = await DeviceDetectionService.GetOperatingSystemAsync();
            isMacOs = os == LocalFinanceManager.Services.ClientOperatingSystem.MacOS;

            if (!isTouchDevice)
            {
                dotNetRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.registerGlobalShortcuts", dotNetRef, "HandleGlobalShortcut");
                globalShortcutsRegistered = true;
            }

            touchDeviceDetected = true;
            StateHasChanged();
        }
        catch
        {
            isTouchDevice = false;
            isMacOs = false;
            touchDeviceDetected = true;
        }
    }

    [JSInvokable]
    public Task HandleGlobalShortcut(string key)
    {
        if (key == "?" && !showShortcutHelp)
        {
            showShortcutHelp = true;
            StateHasChanged();
        }
        else if (key == "Escape")
        {
            if (showAssignModal)
            {
                CloseAssignModal();
                StateHasChanged();
                return Task.CompletedTask;
            }

            if (showBulkAssignModal)
            {
                CloseBulkAssignModal();
                StateHasChanged();
                return Task.CompletedTask;
            }

            if (showSplitEditor)
            {
                CloseSplitEditor();
                StateHasChanged();
                return Task.CompletedTask;
            }

            if (showAuditTrail)
            {
                CloseAuditTrail();
                StateHasChanged();
                return Task.CompletedTask;
            }

            if (showShortcutHelp)
            {
                showShortcutHelp = false;
                StateHasChanged();
            }
        }

        return Task.CompletedTask;
    }

    private async Task LoadAccountsAsync()
    {
        accounts = await AccountRepository.GetActiveAsync();
    }

    private async Task LoadTransactionsAsync()
    {
        _lastLoadHadEmptyUser = UserContext.GetCurrentUserId() == Guid.Empty;
        loading = true;
        try
        {
            List<LocalFinanceManager.Models.Transaction> transactions;
            if (selectedAccountId.HasValue)
            {
                transactions = await TransactionRepository.GetByAccountIdWithSplitsAsync(selectedAccountId.Value);
            }
            else
            {
                transactions = await TransactionRepository.GetAllWithSplitsAsync();
            }

            // Convert to DTOs
            transactionDtos = transactions.Select(t => new TransactionDto
            {
                Id = t.Id,
                Amount = t.Amount,
                Date = t.Date,
                Description = t.Description,
                Counterparty = t.Counterparty,
                AccountId = t.AccountId,
                AccountCurrency = t.Account?.Currency,
                ExternalId = t.ExternalId,
                SourceFileName = t.SourceFileName,
                ImportedAt = t.ImportedAt,
                XMin = t.XMin,
                AccountBudgetPlanId = t.Account?.CurrentBudgetPlanId,
                Splits = t.AssignedParts?.Select(s => new TransactionSplitDetailDto
                {
                    Id = s.Id,
                    BudgetLineId = s.BudgetLineId,
                    BudgetLineName = s.BudgetLine?.Category?.Name ?? "Onbekend",
                    Amount = s.Amount,
                    Note = s.Note
                }).ToList()
            }).OrderByDescending(t => t.Date).ToList();

            // Reset stored confidence scores when transaction list is refreshed
            _suggestionConfidences.Clear();

            // Preload ML suggestion confidences for unassigned transactions so that
            // "has-suggestion" / "no-suggestion" filters are stable and deterministic
            // from the moment the list is rendered, rather than depending on async badge loading.
            // Preload is capped at MaxMlPreloadCount to avoid allocating thousands of Tasks for
            // large transaction histories; items beyond the cap are simply absent from
            // _suggestionConfidences and are treated as "no suggestion" by the filter.
            const int MaxMlPreloadCount = 100;
            var unassigned = transactionDtos.Where(t => !t.IsAssigned).Take(MaxMlPreloadCount).ToList();
            if (unassigned.Count > 0)
            {
                const int maxConcurrentPredictionRequests = 4;
                var predictionThrottle = new System.Threading.SemaphoreSlim(maxConcurrentPredictionRequests);
                var suggestionConfidenceLock = new object();

                try
                {
                    var predictionTasks = unassigned.Select(async t =>
                    {
                        await predictionThrottle.WaitAsync();
                        try
                        {
                            var prediction = await MLService.PredictCategoryAsync(t.Id);
                            if (prediction != null)
                            {
                                lock (suggestionConfidenceLock)
                                {
                                    _suggestionConfidences[t.Id] = prediction.Confidence;
                                }
                            }
                        }
                        catch (Exception ex)
                        {
                            Logger.LogDebug(ex, "ML prediction unavailable for transaction {TransactionId}", t.Id);
                        }
                        finally
                        {
                            predictionThrottle.Release();
                        }
                    });

                    await Task.WhenAll(predictionTasks);
                }
                finally
                {
                    predictionThrottle.Dispose();
                }
            }

            ApplyFilters();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load transactions for account filter {AccountId}", selectedAccountId);
            transactionDtos = new List<TransactionDto>();
            filteredTransactions = new List<TransactionDto>();
            filteredTotalAmount = 0;
            unassignedCount = 0;
            errorMessage = "Transacties laden is mislukt. Probeer opnieuw.";
        }
        finally
        {
            loading = false;
            loadedAccountId = selectedAccountId?.ToString() ?? "all";
        }
    }

    private void ApplyFilters()
    {
        var query = transactionDtos.AsEnumerable();

        // Apply assignment status filter
        query = filterState.AssignmentStatus switch
        {
            "assigned" => query.Where(t => t.IsAssigned),
            "unassigned" => query.Where(t => !t.IsAssigned),
            "split" => query.Where(t => t.Splits != null && t.Splits.Count > 1),
            "auto-applied" => query, // TODO: Add auto-applied tracking
            _ => query
        };

        // Apply date range filter
        if (filterState.DateRange != "all")
        {
            var now = DateTime.Now;
            var startDate = filterState.DateRange switch
            {
                "last7" => now.AddDays(-7),
                "last30" => now.AddDays(-30),
                "last90" => now.AddDays(-90),
                "custom" => filterState.CustomStartDate ?? DateTime.MinValue,
                _ => DateTime.MinValue
            };

            var endDate = filterState.DateRange == "custom"
            ? filterState.CustomEndDate ?? DateTime.MaxValue
            : DateTime.MaxValue;

            query = query.Where(t => t.Date >= startDate && t.Date <= endDate);
        }

        // Apply amount range filter
        if (filterState.MinAmount.HasValue)
        {
            query = query.Where(t => Math.Abs(t.Amount) >= filterState.MinAmount.Value);
        }
        if (filterState.MaxAmount.HasValue)
        {
            query = query.Where(t => Math.Abs(t.Amount) <= filterState.MaxAmount.Value);
        }

        // Apply account filter (if set via QuickFilters)
        if (filterState.SelectedAccountId.HasValue)
        {
            query = query.Where(t => t.AccountId == filterState.SelectedAccountId.Value);
        }

        // Apply ML suggestion filter: show only transactions with a loaded ML suggestion
        if (_suggestionFilter == "has-suggestion")
        {
            query = query.Where(t => _suggestionConfidences.ContainsKey(t.Id));
        }
        else if (_suggestionFilter == "no-suggestion")
        {
            query = query.Where(t => !t.IsAssigned && !_suggestionConfidences.ContainsKey(t.Id));
        }

        // Apply suggestion status filter from QuickFilters panel
        if (filterState.SuggestionStatus == "has-suggestion")
        {
            query = query.Where(t => _suggestionConfidences.ContainsKey(t.Id));
        }
        else if (filterState.SuggestionStatus == "no-suggestion")
        {
            query = query.Where(t => !t.IsAssigned && !_suggestionConfidences.ContainsKey(t.Id));
        }

        // Apply sort
        IOrderedEnumerable<TransactionDto> ordered = _sortBy == "confidence-desc"
            ? query.OrderByDescending(t => _suggestionConfidences.GetValueOrDefault(t.Id, 0f))
                   .ThenByDescending(t => t.Date)
            : query.OrderByDescending(t => t.Date);

        filteredTransactions = ordered.ToList();
        filteredTotalAmount = filteredTransactions.Sum(t => t.Amount);
        unassignedCount = transactionDtos.Count(t => !t.IsAssigned);

        if (filteredTransactions.Count == 0)
        {
            focusedRowIndex = 0;
        }
        else if (focusedRowIndex >= filteredTransactions.Count)
        {
            focusedRowIndex = filteredTransactions.Count - 1;
        }
    }

    private void OnFiltersChanged(FilterState newFilters)
    {
        filterState = newFilters;
        ApplyFilters();
        StateHasChanged();
    }

    private async Task OnAccountChanged()
    {
        selectedAccountId = string.IsNullOrEmpty(selectedAccountIdString)
        ? null
        : Guid.Parse(selectedAccountIdString);

        await LoadTransactionsAsync();
    }

    private void SetFocusedRow(int rowIndex)
    {
        focusedRowIndex = rowIndex;
    }

    private async Task HandleTableKeyDown(KeyboardEventArgs e)
    {
        if (isTouchDevice || filteredTransactions.Count == 0)
        {
            return;
        }

        var key = e.Key;
        var isModifierPressed = e.CtrlKey || e.MetaKey;

        if (isModifierPressed && key.Equals("a", StringComparison.OrdinalIgnoreCase))
        {
            selectedTransactionIds = filteredTransactions.Select(t => t.Id).ToList();
            StateHasChanged();
            return;
        }

        if (isModifierPressed && key.Equals("d", StringComparison.OrdinalIgnoreCase))
        {
            selectedTransactionIds.Clear();
            StateHasChanged();
            return;
        }

        if (key == "/")
        {
            await InvokeAsync(StateHasChanged);
            await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.focusSelector", "#assignmentStatusFilter");
            return;
        }

        if (key == "ArrowDown")
        {
            focusedRowIndex = Math.Min(focusedRowIndex + 1, filteredTransactions.Count - 1);
            await FocusRowAsync(focusedRowIndex);
            return;
        }

        if (key == "ArrowUp")
        {
            focusedRowIndex = Math.Max(focusedRowIndex - 1, 0);
            await FocusRowAsync(focusedRowIndex);
            return;
        }

        if (key == "Home")
        {
            focusedRowIndex = 0;
            await FocusRowAsync(focusedRowIndex);
            return;
        }

        if (key == "End")
        {
            focusedRowIndex = filteredTransactions.Count - 1;
            await FocusRowAsync(focusedRowIndex);
            return;
        }


        if (key == "Enter")
        {
            OpenAssignModal(filteredTransactions[focusedRowIndex]);
        }
    }

    private void HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Escape")
        {
            return;
        }

        if (showAssignModal)
        {
            CloseAssignModal();
            StateHasChanged();
            return;
        }

        if (showShortcutHelp)
        {
            showShortcutHelp = false;
            StateHasChanged();
        }
    }

    private async Task FocusRowAsync(int rowIndex)
    {
        await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.focusSelector", $"tr[data-row-index='{rowIndex}']");
        StateHasChanged();
    }

    private void OpenAssignModal(TransactionDto transaction)
    {
        selectedTransaction = transaction;
        showAssignModal = true;
    }

    private void CloseAssignModal()
    {
        showAssignModal = false;
        selectedTransaction = null;
    }

    private async Task OnAssignmentSuccess()
    {
        // Reload transactions to reflect the assignment
        await LoadTransactionsAsync();
        StateHasChanged();
    }

    private void OpenAuditTrail(Guid transactionId)
    {
        auditTransactionId = transactionId;
        showAuditTrail = true;
    }

    private void CloseAuditTrail()
    {
        showAuditTrail = false;
        auditTransactionId = null;
    }

    private void OpenSplitEditor(TransactionDto transaction)
    {
        splitTransaction = transaction;
        showSplitEditor = true;
    }

    private void CloseSplitEditor()
    {
        showSplitEditor = false;
        splitTransaction = null;
    }

    private async Task OnSplitSaved()
    {
        await LoadTransactionsAsync();
        StateHasChanged();
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (e.Value is bool isChecked && isChecked)
        {
            selectedTransactionIds = filteredTransactions.Select(t => t.Id).ToList();
        }
        else
        {
            selectedTransactionIds.Clear();
        }
        StateHasChanged();
    }

    private void ToggleSelectTransaction(Guid transactionId)
    {
        if (selectedTransactionIds.Contains(transactionId))
        {
            selectedTransactionIds.Remove(transactionId);
        }
        else
        {
            selectedTransactionIds.Add(transactionId);
        }
        StateHasChanged();
    }

    private void ClearSelection()
    {
        selectedTransactionIds.Clear();
        StateHasChanged();
    }

    private void OpenBulkAssignModal()
    {
        showBulkAssignModal = true;
    }

    private void CloseBulkAssignModal()
    {
        showBulkAssignModal = false;
    }

    private async Task OnBulkAssigned()
    {
        await LoadTransactionsAsync();
        selectedTransactionIds.Clear();
        StateHasChanged();
    }

    private Guid? GetBulkBudgetPlanId()
    {
        // Determine the budget plan ID for the current bulk selection.
        // Validate that all selected transactions share the same account/budget plan.
        if (!selectedTransactionIds.Any())
        {
            return null;
        }

        var selectedTransactions = transactionDtos
        .Where(t => selectedTransactionIds.Contains(t.Id))
        .ToList();

        if (!selectedTransactions.Any())
        {
            return null;
        }

        var distinctBudgetPlanIds = selectedTransactions
        .Select(t => t.AccountBudgetPlanId)
        .Distinct()
        .ToList();

        // Only return a budget plan ID if all selected transactions share the same one
        return distinctBudgetPlanIds.Count == 1 ? distinctBudgetPlanIds[0] : null;
    }

    private async Task OnSuggestionAccepted(Guid transactionId)
    {
        // Reload transactions to reflect the accepted suggestion
        await LoadTransactionsAsync();
        StateHasChanged();
    }

    private void HandleConfidenceLoaded(Guid transactionId, float confidence)
    {
        _suggestionConfidences[transactionId] = confidence;

        // Re-apply filters so confidence-descending sort stays current as badges load
        if (_sortBy == "confidence-desc")
        {
            ApplyFilters();
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (globalShortcutsRegistered)
            {
                await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.unregisterGlobalShortcuts");
            }
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnection during disposal; circuit is already closed.
        }
        catch (JSException)
        {
            // Ignore JS errors during disposal to avoid teardown failures.
        }

        dotNetRef?.Dispose();
    }
}