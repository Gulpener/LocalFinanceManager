@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using LocalFinanceManager.Services
@inject IAuthService AuthService
@inject IAuthStateNotifier AuthStateNotifier
@inject NavigationManager Navigation

<PageTitle>Inloggen</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2>Inloggen</h2>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
                @if (showResendVerification)
                {
                    <div class="mt-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResendVerificationEmail"
                                disabled="@isResending">
                            @(isResending ? "Bezig..." : "Verificatiemail opnieuw versturen")
                        </button>
                        @if (!string.IsNullOrEmpty(resendMessage))
                        {
                            <div class="mt-1 @(resendSuccess ? "text-success" : "text-danger") small">@resendMessage</div>
                        }
                    </div>
                }
            </div>
        }

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="login">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="email" class="form-label">E-mailadres</label>
                <InputText id="email" class="form-control" @bind-Value="loginModel.Email" type="email"
                           autocomplete="email" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Wachtwoord</label>
                <InputText id="password" class="form-control" @bind-Value="loginModel.Password" type="password"
                           autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@isSubmitting">
                @(isSubmitting ? "Bezig met inloggen..." : "Inloggen")
            </button>
        </EditForm>

        <hr />
        <p class="text-center">
            Nog geen account? <a href="/register">Registreren</a>
        </p>
        <p class="text-center">
            <a href="/password-reset">Wachtwoord vergeten?</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private LoginModel loginModel = new();
    private string? errorMessage;
    private bool showResendVerification;
    private bool isSubmitting;
    private bool isResending;
    private bool resendSuccess;
    private string? resendMessage;

    private async Task HandleLogin()
    {
        isSubmitting = true;
        errorMessage = null;
        showResendVerification = false;
        resendMessage = null;

        try
        {
            var result = await AuthService.SignInAsync(loginModel.Email, loginModel.Password);

            if (result.Success && !string.IsNullOrEmpty(result.AccessToken))
            {
                await AuthStateNotifier.NotifyUserLoggedInAsync(result.AccessToken);
                var destination = GetSafeReturnUrl();
                Navigation.NavigateTo(destination);
            }
            else if (result.EmailVerified == false)
            {
                errorMessage = "E-mail niet geverifieerd. Controleer uw inbox en verifieer uw e-mailadres.";
                showResendVerification = true;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Inloggen mislukt. Controleer uw gegevens.";
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task ResendVerificationEmail()
    {
        isResending = true;
        resendMessage = null;
        resendSuccess = false;
        try
        {
            var result = await AuthService.ResendVerificationEmailAsync(loginModel.Email);
            resendSuccess = result.Success;
            resendMessage = result.Success
                ? "Verificatiemail verstuurd. Controleer uw inbox."
                : result.ErrorMessage ?? "Versturen van verificatiemail mislukt.";
        }
        finally
        {
            isResending = false;
        }
    }

    private string GetSafeReturnUrl()
    {
        // Only allow local paths (starts with / but not //) to prevent open redirect.
        // Also reject returnUrls that point back to /login to avoid redirect loops.
        if (!string.IsNullOrEmpty(ReturnUrl)
            && ReturnUrl.StartsWith('/')
            && !ReturnUrl.StartsWith("//")
            && !ReturnUrl.TrimStart('/').StartsWith("login", StringComparison.OrdinalIgnoreCase))
        {
            return ReturnUrl;
        }

        return "/";
    }

    private sealed class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = string.Empty;
    }
}
