@using LocalFinanceManager.DTOs
@using LocalFinanceManager.Models
@using LocalFinanceManager.Services
@using LocalFinanceManager.Data.Repositories
@inject ITransactionAssignmentService AssignmentService
@inject IBudgetLineRepository BudgetLineRepository
@inject IBudgetPlanRepository BudgetPlanRepository
@inject IRecentCategoriesService RecentCategoriesService
@inject IJSRuntime JSRuntime
@inject ILogger<TransactionAssignModal> Logger
@implements IAsyncDisposable

@if (IsVisible && Transaction != null)
{
    <div id="transactionAssignModal" class="modal fade show d-block" tabindex="-1"
         style="background-color: rgba(0,0,0,0.5);" role="dialog" aria-modal="true" aria-labelledby="assignModalTitle"
         @onclick="Close" @onkeydown="HandleKeyDown" @ref="modalContainerRef">
        <div class="modal-dialog modal-lg" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="assignModalTitle">Transactie toewijzen@TransactionYearSuffix</h5>
                    <button type="button" class="btn-close" @onclick="Close"
                            aria-label="Druk op Esc om te sluiten"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle"></i> @errorMessage
                        </div>
                    }

                    <!-- Transaction Details -->
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="card-subtitle mb-2 text-muted">Transactie details</h6>
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Datum:</dt>
                                <dd class="col-sm-9">@Transaction?.Date.ToString("dd-MM-yyyy")</dd>

                                <dt class="col-sm-3">Beschrijving:</dt>
                                <dd class="col-sm-9">@Transaction?.Description</dd>

                                <dt class="col-sm-3">Tegenpartij:</dt>
                                <dd class="col-sm-9">@(Transaction?.Counterparty ?? "-")</dd>

                                <dt class="col-sm-3">Bedrag:</dt>
                                <dd class="col-sm-9">
                                    <span class="@(Transaction?.Amount >= 0 ? "text-success" : "text-danger") fw-bold">
                                        @Transaction?.Amount.ToString("C2")
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <!-- Current Assignment Status -->
                    @if (Transaction?.Splits?.Any() == true)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i>
                            Deze transactie is al toegewezen aan:
                            <ul class="mb-0 mt-2">
                                @foreach (var split in Transaction.Splits)
                                {
                                    <li>
                                        <strong>@split.BudgetLineName</strong>
                                        @if (!string.IsNullOrEmpty(split.Note))
                                        {
                                            <span class="text-muted"> - @split.Note</span>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <!-- Recent Budget Lines Pills -->
                    @if (recentBudgetLines != null && recentBudgetLines.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="bi bi-clock-history"></i> Recent gebruikt
                            </label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var budgetLine in recentBudgetLines)
                                {
                                    <button type="button"
                                            class="btn btn-sm @(selectedBudgetLineId == budgetLine.Id.ToString() ? "btn-primary" : "btn-outline-primary")"
                                            @onclick="() => SelectBudgetLine(budgetLine.Id.ToString())" @onclick:stopPropagation>
                                        @budgetLine.CategoryName
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <!-- Budget Line Selection -->
                    <div class="mb-3">
                        <label for="budgetLineSelect" class="form-label">Budgetlijn <span
                            class="text-danger">*</span></label>
                            @if (budgetLines == null)
                            {
                                <select id="budgetLineSelect" class="form-select" disabled>
                                    <option>Laden...</option>
                                </select>
                            }
                            else if (budgetLines.Count == 0)
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle"></i>
                                    Geen budgetlijnen gevonden voor deze rekening. Maak eerst budgetlijnen aan.
                                </div>
                            }
                            else
                            {
                                <select id="budgetLineSelect" class="form-select" @bind="selectedBudgetLineId"
                                        @ref="budgetLineSelectRef">
                                    <option value="">-- Selecteer een budgetlijn --</option>
                                    @foreach (var budgetLine in budgetLines)
                                    {
                                        <option value="@budgetLine.Id">@budgetLine.CategoryName</option>
                                    }
                                </select>
                            }
                        </div>

                        <!-- Optional Note -->
                        <div class="mb-3">
                            <label for="noteInput" class="form-label">Notitie (optioneel)</label>
                            <textarea id="noteInput" class="form-control" rows="2" maxlength="500" @bind="note"
                                      placeholder="Voeg een notitie toe..."></textarea>
                            <div class="form-text">@(note?.Length ?? 0)/500 karakters</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button id="assignCancelButton" type="button" class="btn btn-secondary" @onclick="Close"
                                disabled="@isSubmitting">
                            Annuleren
                        </button>
                        <button id="assignSaveButton" type="button" class="btn btn-primary" @onclick="AssignTransaction"
                                disabled="@(!CanAssign || isSubmitting)">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            }
                            Toewijzen
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

@code {
    [Parameter]
    public TransactionDto? Transaction { get; set; }

    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnAssignmentSuccess { get; set; }

    private List<BudgetLineDto>? budgetLines;
    private List<BudgetLineDto>? recentBudgetLines;
    private string? selectedBudgetLineId;
    private string? note;
    private string? errorMessage;
    private bool isSubmitting;
    private bool isFocusTrapActive;
    private bool isInitialFocusSet;
    private bool wasVisible;
    private ElementReference modalContainerRef;
    private ElementReference budgetLineSelectRef;

    private string TransactionYearSuffix => Transaction?.Date.Year > 0
        ? $" ({Transaction.Date.Year})"
        : string.Empty;

    private bool CanAssign => !string.IsNullOrEmpty(selectedBudgetLineId) && budgetLines?.Count > 0;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsVisible)
        {
            await ReleaseFocusTrapAsync();
            isInitialFocusSet = false;
            wasVisible = false;
        }

        if (IsVisible && !wasVisible)
        {
            isInitialFocusSet = false;
            wasVisible = true;
        }

        if (IsVisible && Transaction != null)
        {
            await LoadBudgetLines();
            await LoadRecentCategories();
            ResetForm();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsVisible)
        {
            isInitialFocusSet = false;
            return;
        }

        if (!isFocusTrapActive)
        {
            await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.trapFocus", "#transactionAssignModal");
            isFocusTrapActive = true;
        }

        if (isInitialFocusSet)
        {
            return;
        }

        try
        {
            if (budgetLineSelectRef.Context != null)
            {
                // Budget lines are loaded — focus the select and mark as done
                isInitialFocusSet = true;
                await budgetLineSelectRef.FocusAsync();
            }
            else if (budgetLines != null)
            {
                // Budget lines loaded but no select available (e.g. empty list) — focus modal
                isInitialFocusSet = true;
                await modalContainerRef.FocusAsync();
            }
            // else: budget lines not loaded yet — don't set isInitialFocusSet,
            // so we retry after the next render when lines are populated
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to set focus on budget line selector");
        }
    }

    private async Task LoadBudgetLines()
    {
        try
        {
            errorMessage = null;

            if (Transaction == null)
            {
                errorMessage = "Geen transactie geselecteerd.";
                budgetLines = new List<BudgetLineDto>();
                return;
            }

            Logger.LogInformation("LoadBudgetLines called for Transaction {TransactionId}", Transaction.Id);

            // Find budget plan for transaction's year
            var transactionYear = Transaction.Date.Year;
            Logger.LogInformation("Looking for budget plan for AccountId={AccountId}, Year={Year}",
            Transaction.AccountId, transactionYear);

            var budgetPlan = await BudgetPlanRepository.GetByAccountAndYearAsync(Transaction.AccountId, transactionYear);

            if (budgetPlan == null)
            {
                errorMessage = $"Geen budgetplan gevonden voor {transactionYear}. Maak een budgetplan voor {transactionYear} aan om deze transactie toe te wijzen.";
                budgetLines = new List<BudgetLineDto>();
                return;
            }

            // Load budget lines for this budget plan
            Logger.LogInformation("Loading budget lines for BudgetPlanId={BudgetPlanId} (Year {Year})",
            budgetPlan.Id, transactionYear);
            var lines = await BudgetLineRepository.GetByBudgetPlanIdAsync(budgetPlan.Id);
            Logger.LogInformation("Received {Count} budget lines from repository", lines.Count);
            budgetLines = lines.Select(bl => new BudgetLineDto
            {
                Id = bl.Id,
                BudgetPlanId = bl.BudgetPlanId,
                CategoryId = bl.CategoryId,
                CategoryName = bl.Category?.Name ?? "Onbekend",
                MonthlyAmounts = bl.MonthlyAmounts,
                YearTotal = bl.MonthlyAmounts.Sum(),
                Notes = bl.Notes,
                XMin = bl.XMin
            }).ToList();

            if (budgetLines.Count == 0)
            {
                errorMessage = $"Het budgetplan voor {transactionYear} heeft nog geen budgetlijnen. Ga naar Budgetbeheer om categorieën en budgetlijnen toe te voegen.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load budget lines for transaction {TransactionId}", Transaction?.Id);
            errorMessage = "Fout bij het laden van budgetlijnen.";
            budgetLines = new List<BudgetLineDto>();
        }
    }

    private void ResetForm()
    {
        selectedBudgetLineId = null;
        note = null;
        errorMessage = null;
        isSubmitting = false;
    }

    private async Task LoadRecentCategories()
    {
        try
        {
            if (budgetLines == null || !budgetLines.Any())
            {
                recentBudgetLines = new List<BudgetLineDto>();
                return;
            }

            var recentCategoryIds = await RecentCategoriesService.GetRecentCategoriesAsync(5);
            var indexMap = recentCategoryIds
                .Select((id, index) => new { id, index })
                .ToDictionary(x => x.id, x => x.index);

            recentBudgetLines = budgetLines
                .Where(bl => recentCategoryIds.Contains(bl.CategoryId))
                .OrderBy(bl => indexMap.TryGetValue(bl.CategoryId, out var idx) ? idx : int.MaxValue)
                .Take(5)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load recent categories");
            recentBudgetLines = new List<BudgetLineDto>();
        }
    }

    private void SelectBudgetLine(string budgetLineId)
    {
        selectedBudgetLineId = budgetLineId;
        StateHasChanged();
    }

    private async Task AssignTransaction()
    {
        if (Transaction == null || string.IsNullOrEmpty(selectedBudgetLineId))
            return;

        try
        {
            isSubmitting = true;
            errorMessage = null;

            var budgetLineGuid = Guid.Parse(selectedBudgetLineId);
            var request = new AssignTransactionRequest
            {
                BudgetLineId = budgetLineGuid,
                Note = note,
                XMin = Transaction.XMin
            };

            await AssignmentService.AssignTransactionAsync(Transaction.Id, request);

            // Track category usage for recent categories
            var selectedBudgetLine = budgetLines?.FirstOrDefault(bl => bl.Id == budgetLineGuid);
            if (selectedBudgetLine != null)
            {
                await RecentCategoriesService.TrackCategoryUsageAsync(selectedBudgetLine.CategoryId);
            }

            await OnAssignmentSuccess.InvokeAsync();
            await Close();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to assign transaction {TransactionId}", Transaction.Id);

            // Use structured error handling based on exception type instead of parsing exception messages
            errorMessage = ex switch
            {
                InvalidOperationException => "De transactie kon niet worden toegewezen.",
                KeyNotFoundException => "De geselecteerde budgetlijn is niet gevonden.",
                _ => "Er is een fout opgetreden bij het toewijzen van de transactie."
            };
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await Close();
            return;
        }

        if (e.Key == "Enter")
        {
            var isSaveButtonFocused = await JSRuntime.InvokeAsync<bool>("localFinanceKeyboard.isActiveElement",
                "#assignSaveButton");
            if (isSaveButtonFocused && CanAssign && !isSubmitting)
            {
                await AssignTransaction();
            }
        }
    }

    private async Task Close()
    {
        await ReleaseFocusTrapAsync();

        isInitialFocusSet = false;
        wasVisible = false;
        ResetForm();
        await OnClose.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await ReleaseFocusTrapAsync();
    }

    private async ValueTask ReleaseFocusTrapAsync()
    {
        if (!isFocusTrapActive)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.releaseFocusTrap");
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS interop errors during circuit teardown.
        }
        catch (JSException)
        {
            // Ignore JS interop errors during disposal.
        }
        finally
        {
            isFocusTrapActive = false;
        }
    }
}