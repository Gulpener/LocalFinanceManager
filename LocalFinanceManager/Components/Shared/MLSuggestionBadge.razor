@using LocalFinanceManager.DTOs.ML
@using System.Net.Http.Json
@using System.Globalization
@inject HttpClient Http
@inject IJSRuntime JS
@inject ILogger<MLSuggestionBadge> Logger

<style>
    .ml-suggestion-wrapper {
        position: relative;
        display: inline-block;
    }

    .ml-suggestion-tooltip {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        margin-top: 0.25rem;
        padding: 0.25rem 0.5rem;
        background: #212529;
        color: #ffffff;
        border-radius: 0.25rem;
        font-size: 0.75rem;
        white-space: nowrap;
        z-index: 1060;
    }

    .ml-suggestion-wrapper:hover .ml-suggestion-tooltip {
        display: block;
    }
</style>

@if (_isLoading && !_isHidden)
{
    <span class="badge bg-secondary">
        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
        Laden...
    </span>
}
else if (_noModelAvailable && !_isHidden)
{
    <span class="badge bg-warning text-dark" title="Nog geen ML-model getraind. Train een model om suggesties te ontvangen."
          data-testid="no-model-badge">
        <i class="bi bi-info-circle"></i> Geen ML-model
    </span>
}
else if (_suggestion != null && !_isHidden)
{
    <span class="ml-suggestion-wrapper">
        <span class="badge @GetBadgeClass() position-relative" data-testid="ml-suggestion-badge"
              data-confidence="@_suggestion.Confidence.ToString("0.00", CultureInfo.InvariantCulture)">
            @_suggestion.CategoryName @((_suggestion.Confidence * 100).ToString("F0"))% 🤖

            @if (_isAutoApplied)
            {
                <span class="ms-1" title="Automatisch toegewezen">✓</span>
            }

            @if (!_isProcessing)
            {
                <button type="button" class="btn btn-sm btn-link text-white p-0 ms-2 border-0" style="font-size: 0.8rem;"
                        @onclick="AcceptSuggestion" title="Suggestie accepteren" data-testid="accept-suggestion">
                    ✓
                </button>
                <button type="button" class="btn btn-sm btn-link text-white p-0 ms-1 border-0" style="font-size: 0.8rem;"
                        @onclick="RejectSuggestion" title="Suggestie weigeren" data-testid="reject-suggestion">
                    ✗
                </button>
            }
            else
            {
                <span class="spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true"></span>
            }
        </span>
        <span class="ml-suggestion-tooltip" data-testid="suggestion-tooltip">
            @GetTooltipText()
        </span>
    </span>
}

@code {
    [Parameter]
    public Guid TransactionId { get; set; }

    [Parameter]
    public EventCallback OnSuggestionAccepted { get; set; }

    [Parameter]
    public bool IsAutoApplied { get; set; }

    /// <summary>
    /// Called after the suggestion loads (including "no model" case).
    /// Reports the confidence (0 when no model is available).
    /// </summary>
    [Parameter]
    public EventCallback<float> OnConfidenceLoaded { get; set; }

    private SuggestionDto? _suggestion;
    private bool _isLoading = true;
    private bool _isProcessing = false;
    private bool _isHidden = false;
    private bool _isAutoApplied = false;
    private bool _noModelAvailable = false;

    protected override async Task OnInitializedAsync()
    {
        _isAutoApplied = IsAutoApplied;
        await LoadSuggestion();
    }

    private async Task LoadSuggestion()
    {
        try
        {
            _isLoading = true;
            var response = await Http.GetAsync($"/api/suggestions?transactionId={TransactionId}");

            if (response.IsSuccessStatusCode)
            {
                _suggestion = await response.Content.ReadFromJsonAsync<SuggestionDto>();
                _noModelAvailable = false;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                // 404 means no ML model is available
                _noModelAvailable = true;
                _suggestion = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading ML suggestion for transaction {TransactionId}", TransactionId);
            _noModelAvailable = true;
        }
        finally
        {
            _isLoading = false;
            if (OnConfidenceLoaded.HasDelegate)
            {
                await OnConfidenceLoaded.InvokeAsync(_suggestion?.Confidence ?? 0f);
            }
        }
    }

    private async Task AcceptSuggestion()
    {
        if (_suggestion == null || _isProcessing) return;

        try
        {
            _isProcessing = true;

            var feedback = new SuggestionFeedbackDto
            {
                TransactionId = TransactionId,
                Accepted = true,
                FinalCategoryId = _suggestion.CategoryId,
                SuggestedCategoryId = _suggestion.CategoryId,
                SuggestionConfidence = _suggestion.Confidence,
                ModelVersion = _suggestion.ModelVersion
            };

            var response = await Http.PostAsJsonAsync("/api/suggestions/feedback", feedback);

            if (response.IsSuccessStatusCode)
            {
                // Feedback recorded — hide the badge so the user sees the suggestion was fulfilled
                _isHidden = true;
                await ShowToastAsync("Suggestion accepted", "success");
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Failed to accept suggestion for transaction {TransactionId}. Status: {StatusCode}, Response: {ErrorMessage}", TransactionId, response.StatusCode, errorMessage);
                await JS.InvokeVoidAsync("alert", "Kon suggestie niet accepteren.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error while accepting suggestion for transaction {TransactionId}", TransactionId);
            await JS.InvokeVoidAsync("alert", "Kon suggestie niet accepteren.");
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task RejectSuggestion()
    {
        if (_suggestion == null || _isProcessing) return;

        try
        {
            _isProcessing = true;

            // For now, do not send feedback with an empty FinalCategoryId, as the backend
            // expects a valid CategoryId FK. Simply hide the badge locally to indicate
            // that the suggestion was dismissed.
            _isHidden = true;

            await ShowToastAsync("Suggestion dismissed", "info");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error while rejecting suggestion for transaction {TransactionId}", TransactionId);
            await JS.InvokeVoidAsync("alert", "Kon suggestie niet verwerken.");
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private string GetBadgeClass()
    {
        if (_suggestion == null) return "bg-secondary";

        return _suggestion.Confidence switch
        {
            >= 0.8f => "bg-success",
            >= 0.6f => "bg-warning",
            _ => "bg-secondary"
        };
    }

    private string GetTooltipText()
    {
        if (_suggestion == null || _suggestion.Explanation.Count == 0)
        {
            return "Based on: ML model";
        }

        var top3Features = _suggestion.Explanation
            .OrderByDescending(f => f.Importance)
            .Take(3)
            .ToList();

        var featureText = string.Join(", ",
            top3Features.Select(f => $"{FormatFeatureName(f.FeatureName)}: {f.FeatureValue}"));

        return $"Based on: {featureText}";
    }

    private string FormatFeatureName(string featureName)
    {
        // Convert technical feature names to user-friendly labels
        return featureName switch
        {
            "description_token" => "Description",
            "counterparty" => "Counterparty",
            "amount_bin" => "Amount",
            "day_of_week" => "Day of Week",
            "month" => "Month",
            _ => featureName
        };
    }

    private ValueTask ShowToastAsync(string message, string type)
    {
        return JS.InvokeVoidAsync("showToast", message, type);
    }
}