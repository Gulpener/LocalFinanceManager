@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@if (IsVisible)
{
    <div id="shortcutHelpModal" class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);"
         role="dialog" aria-modal="true" aria-labelledby="shortcutHelpTitle" @onkeydown="HandleKeyDown" @ref="modalContainerRef">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="shortcutHelpTitle">
                        <i class="bi bi-keyboard"></i> Toetsenbord sneltoetsen
                    </h5>
                    <button type="button" class="btn-close" @onclick="Close" aria-label="Sluiten"></button>
                </div>
                <div class="modal-body">
                    @if (IsTouchDevice)
                    {
                        <p class="text-muted">Je gebruikt een touch-apparaat. Toetsenbord sneltoetsen zijn uitgeschakeld.</p>

                        <h6 class="mt-3">Touch gebaren</h6>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th style="width: 30%">Gebaar</th>
                                    <th>Actie</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Tik</td>
                                    <td>Selecteer transactie of open actie</td>
                                </tr>
                                <tr>
                                    <td>Swipe</td>
                                    <td>Sluit modaal met sluitknop of swipe-gesture van OS/browser</td>
                                </tr>
                                <tr>
                                    <td>Lang indrukken</td>
                                    <td>Open contextmenu (indien ondersteund)</td>
                                </tr>
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">Gebruik deze sneltoetsen om efficiënter te werken met transacties.</p>

                        <h6 class="mt-3">Algemeen</h6>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th style="width: 30%">Sneltoets</th>
                                    <th>Actie</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><kbd>?</kbd></td>
                                    <td>Toon deze hulp</td>
                                </tr>
                                <tr>
                                    <td><kbd>/</kbd></td>
                                    <td>Focus zoek-/filterinvoer</td>
                                </tr>
                                <tr>
                                    <td><kbd>Esc</kbd></td>
                                    <td>Sluit modaal zonder opslaan</td>
                                </tr>
                            </tbody>
                        </table>

                        <h6 class="mt-3">Transactielijst</h6>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th style="width: 30%">Sneltoets</th>
                                    <th>Actie</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><kbd>Space</kbd></td>
                                    <td>Schakel transactie selectievakje in/uit</td>
                                </tr>
                                <tr>
                                    <td><kbd>@PrimaryModifier</kbd> + <kbd>A</kbd></td>
                                    <td>Selecteer alle zichtbare transacties</td>
                                </tr>
                                <tr>
                                    <td><kbd>@PrimaryModifier</kbd> + <kbd>D</kbd></td>
                                    <td>Deselecteer alle transacties</td>
                                </tr>
                                <tr>
                                    <td><kbd>↑</kbd> / <kbd>↓</kbd></td>
                                    <td>Navigeer tussen transacties</td>
                                </tr>
                                <tr>
                                    <td><kbd>Home</kbd> / <kbd>End</kbd></td>
                                    <td>Ga naar eerste / laatste transactie</td>
                                </tr>
                                <tr>
                                    <td><kbd>Enter</kbd></td>
                                    <td>Open toewijzingsmodaal voor gefocuste transactie</td>
                                </tr>
                            </tbody>
                        </table>

                        <h6 class="mt-3">Modalen (Toewijzen, Split, Bulk)</h6>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th style="width: 30%">Sneltoets</th>
                                    <th>Actie</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><kbd>Tab</kbd></td>
                                    <td>Navigeer tussen formuliervelden</td>
                                </tr>
                                <tr>
                                    <td><kbd>Enter</kbd></td>
                                    <td>Dien formulier in (wanneer opslaan-knop gefocust is)</td>
                                </tr>
                                <tr>
                                    <td><kbd>Esc</kbd></td>
                                    <td>Sluit modaal zonder opslaan</td>
                                </tr>
                                <tr>
                                    <td><kbd>@PrimaryModifier</kbd> + <kbd>+</kbd></td>
                                    <td>Voeg split-rij toe (Split Editor)</td>
                                </tr>
                                <tr>
                                    <td><kbd>@PrimaryModifier</kbd> + <kbd>-</kbd></td>
                                    <td>Verwijder gefocuste split-rij (Split Editor)</td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="alert alert-info mt-3">
                            <i class="bi bi-info-circle"></i>
                            <strong>Tip:</strong> Op Mac gebruik je <kbd>Cmd</kbd> in plaats van <kbd>Ctrl</kbd>.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="Print">
                        <i class="bi bi-printer"></i> Print
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Close">Sluiten</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public bool IsTouchDevice { get; set; }

    [Parameter]
    public bool IsMacOs { get; set; }

    private string PrimaryModifier => IsMacOs ? "Cmd" : "Ctrl";
    private bool isFocusTrapActive;
    private bool isInitialFocusSet;
    private bool wasVisible;
    private ElementReference modalContainerRef;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsVisible)
        {
            isInitialFocusSet = false;
        }

        if (IsVisible && !wasVisible)
        {
            isInitialFocusSet = false;
            wasVisible = true;
        }

        if (IsVisible)
        {
            return;
        }

        if (wasVisible)
        {
            await ReleaseFocusTrapAsync();
            wasVisible = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsVisible)
        {
            return;
        }

        if (!isFocusTrapActive)
        {
            await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.trapFocus", "#shortcutHelpModal");
            isFocusTrapActive = true;
        }

        if (!isInitialFocusSet)
        {
            await modalContainerRef.FocusAsync();
            isInitialFocusSet = true;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await Close();
        }
    }

    private async Task Print()
    {
        await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.printPage");
    }

    private async Task Close()
    {
        await ReleaseFocusTrapAsync();
        isInitialFocusSet = false;
        wasVisible = false;
        await OnClose.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await ReleaseFocusTrapAsync();
    }

    private async ValueTask ReleaseFocusTrapAsync()
    {
        if (!isFocusTrapActive)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("localFinanceKeyboard.releaseFocusTrap");
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS interop errors during circuit teardown.
        }
        catch (JSException)
        {
            // Ignore JS interop errors during disposal.
        }
        finally
        {
            isFocusTrapActive = false;
        }
    }
}