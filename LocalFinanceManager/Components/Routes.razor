@using Microsoft.AspNetCore.Components.Authorization
@using LocalFinanceManager.Services
@using LocalFinanceManager.Data
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IBlazorCircuitUser CircuitUser
@inject AppDbContext DbContext
@inject ILogger<Routes> Logger
@implements IDisposable

@if (_circuitReady)
{
    <Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)"
            OnNavigateAsync="HandleNavigateAsync">
        <Found Context="routeData">
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
}

@code {
    private bool _circuitReady;
    private bool _authStateSubscriptionSet;

    private static readonly HashSet<string> AnonymousRoutes = new(StringComparer.OrdinalIgnoreCase)
    {
        "",
        "login",
        "register",
        "logout",
        "password-reset",
        "not-found"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            if (!_authStateSubscriptionSet)
            {
                AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
                _authStateSubscriptionSet = true;
            }

            await EnsureCircuitUserInitializedAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize circuit user context during first render. The user may see a login page or reduced functionality.");
        }
        finally
        {
            if (!_circuitReady)
            {
                _circuitReady = true;
                StateHasChanged();
            }
        }
    }

    private async Task EnsureCircuitUserInitializedAsync()
    {
        if (CircuitUser.IsInitialized)
        {
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        await InitializeCircuitUserFromAuthStateAsync(authState);
    }

    private async Task InitializeCircuitUserFromAuthStateAsync(AuthenticationState authState)
    {
        var user = authState.User;
        var isAuthenticated = user.Identity?.IsAuthenticated ?? false;

        // When the authentication state is unauthenticated, reset the circuit user
        // to avoid keeping stale identity associated with this circuit.
        if (!isAuthenticated)
        {
            CircuitUser.Reset();
            // No circuit user is initialized for anonymous users.
            return;
        }

        var subClaim = user.FindFirst("sub")?.Value;
        if (string.IsNullOrEmpty(subClaim))
        {
            // If we cannot identify the remote user, reset any existing circuit user
            // to avoid using a stale identity.
            CircuitUser.Reset();
            return;
        }

        var localUser = await DbContext.Users
            .AsNoTracking()
            .FirstOrDefaultAsync(u => u.SupabaseUserId == subClaim);
        if (localUser == null)
        {
            // If there is no corresponding local user, reset any existing circuit user
            // to avoid using a stale identity.
            CircuitUser.Reset();
            return;
        }

        var email = user.FindFirst("email")?.Value ?? localUser.Email;
        CircuitUser.Initialize(localUser.Id, email);
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> authenticationStateTask)
    {
        try
        {
            var authState = await authenticationStateTask;
            await InitializeCircuitUserFromAuthStateAsync(authState);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update circuit user context when authentication state changed.");
        }
    }

    private async Task HandleNavigateAsync(NavigationContext context)
    {
        var targetPath = context.Path.Trim('/');

        // Strip query string before checking anonymous routes so that
        // paths like "login?returnUrl=..." still match "login".
        var pathWithoutQuery = targetPath.Split('?')[0];
        if (AnonymousRoutes.Contains(pathWithoutQuery))
        {
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;

        if (isAuthenticated)
        {
            return;
        }

        // context.Path already includes the leading '/', so avoid producing a double-slash
        // like "//transactions" which GetSafeReturnUrl() in Login.razor rejects as open-redirect.
        var returnUrl = string.IsNullOrWhiteSpace(context.Path)
            ? "/"
            : $"/{context.Path.TrimStart('/')}";

        // forceLoad: false (SPA pushState) is used here because forceLoad: true in an
        // interactive Blazor Server circuit causes the circuit to be disposed before the
        // navigation message is delivered to the client, resulting in the browser never
        // navigating to /login. SPA navigation keeps the circuit alive and reliably
        // changes the URL, which Playwright's ToHaveURLAsync detects correctly.
        Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: false);
    }

    public void Dispose()
    {
        if (_authStateSubscriptionSet)
        {
            AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
            _authStateSubscriptionSet = false;
        }
    }
}